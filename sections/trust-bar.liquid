{%- style -%}
  .trust-bar {
    background-color: #f9f9f9;
    padding: 2rem 0;
    border-bottom: 1px solid #eee;
  }
  .trust-bar__container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
    flex-wrap: wrap;
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem;
    font-weight: 600;
    color: #333;
  }
  .trust-bar__logo {
    height: 30px;
    width: auto;
  }
  @media screen and (max-width: 749px) {
    .trust-bar__container {
      gap: 2rem;
    }
    .trust-bar__item {
      font-size: 1.2rem;
    }
    .trust-bar__logo {
      height: 24px;
    }
  }
{%- endstyle -%}

<div class="trust-bar">
  <div class="page-width">
    <div class="trust-bar__container">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: height: 60 }}"
              alt="{{ block.settings.text }}"
              class="trust-bar__logo"
              loading="lazy"
            >
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <span>{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trusted Shop"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "Trustpilot" } },
        { "type": "trust_item", "settings": { "text": "Thuiswinkel Waarborg" } }
      ]
    }
  ]
}
{% endschema %}
