{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #FooterLogos-{{ section.id }} {
    {%- assign bw = section.settings.border_width -%}
    {%- assign bc = section.settings.border_color -%}
    {%- assign bs = section.settings.border_style -%}

    {%- if section.settings.border_position == 'top' or section.settings.border_position == 'both' -%}
      border-top: {{ bw }}px {{ bs }} {{ bc }};
    {%- endif -%}
    {%- if section.settings.border_position == 'bottom' or section.settings.border_position == 'both' -%}
      border-bottom: {{ bw }}px {{ bs }} {{ bc }};
    {%- endif -%}
  }

  .footer-logos__container {
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ section.settings.alignment }};
    align-items: center;
    gap: {{ section.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-logos__container {
      gap: {{ section.settings.gap }}px;
    }
  }

  .footer-logos__item {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  {%- for block in section.blocks -%}
    .logo-{{ block.id }} {
      width: {{ block.settings.width_mobile }}px;
      padding: {{ block.settings.padding_mobile }}px;
      opacity: {{ block.settings.initial_opacity | divided_by: 100.0 }};
      {% if block.settings.grayscale %}
        filter: grayscale(100%);
      {% endif %}
    }

    .footer-logos__item.logo-{{ block.id }}:hover {
      opacity: 1;
      {% if block.settings.grayscale %}
        filter: grayscale(0%);
      {% endif %}
      transform: scale({{ block.settings.hover_scale }});
    }

    .logo-{{ block.id }} {
       background-color: {{ block.settings.item_bg_color }};
       border-radius: {{ block.settings.item_border_radius }}px;
       border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
       overflow: hidden;
    }

    @media screen and (min-width: 750px) {
      .logo-{{ block.id }} {
        width: {{ block.settings.width }}px;
        padding: {{ block.settings.padding }}px;
      }
    }
  {%- endfor -%}

  .footer-logos__item img {
    max-width: 100%;
    height: auto;
    display: block;
  }
{%- endstyle -%}

<div id="FooterLogos-{{ section.id }}" class="section-{{ section.id }}-padding">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="footer-logos__container">
      {%- for block in section.blocks -%}
        <div class="footer-logos__item logo-{{ block.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 400
              | image_tag: loading: 'lazy', alt: block.settings.image.alt
              | default: shop.name
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer Logos",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between logos (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between logos (Mobile)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Border Settings"
    },
    {
      "type": "select",
      "id": "border_position",
      "label": "Border Position",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "both", "label": "Both" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border Width",
      "default": 1
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#eeeeee"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 32
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Logo Link"
        },
        {
          "type": "header",
          "content": "Desktop Settings"
        },
        {
          "type": "range",
          "id": "width",
          "min": 50,
          "max": 300,
          "step": 10,
          "unit": "px",
          "label": "Width",
          "default": 120
        },
        {
          "type": "range",
          "id": "padding",
          "min": 0,
          "max": 50,
          "step": 5,
          "unit": "px",
          "label": "Padding",
          "default": 10
        },
        {
          "type": "header",
          "content": "Mobile Settings"
        },
        {
          "type": "range",
          "id": "width_mobile",
          "min": 30,
          "max": 200,
          "step": 10,
          "unit": "px",
          "label": "Width (Mobile)",
          "default": 80
        },
        {
          "type": "range",
          "id": "padding_mobile",
          "min": 0,
          "max": 50,
          "step": 5,
          "unit": "px",
          "label": "Padding (Mobile)",
          "default": 5
        },
        {
          "type": "header",
          "content": "Effects"
        },
        {
          "type": "checkbox",
          "id": "grayscale",
          "label": "Grayscale by default",
          "default": false
        },
        {
          "type": "range",
          "id": "initial_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "Initial Opacity",
          "default": 100
        },
        {
          "type": "range",
          "id": "hover_scale",
          "min": 0.8,
          "max": 1.2,
          "step": 0.1,
          "label": "Hover Scale Effect",
          "default": 1.1
        },
        {
          "type": "header",
          "content": "Item Styling"
        },
        {
          "type": "color",
          "id": "item_bg_color",
          "label": "Background Color",
          "default": "transparent"
        },
        {
          "type": "range",
          "id": "item_border_radius",
          "min": 0,
          "max": 50,
          "step": 2,
          "unit": "px",
          "label": "Border Radius",
          "default": 0
        },
        {
          "type": "range",
          "id": "item_border_width",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "px",
          "label": "Border Width",
          "default": 0
        },
        {
          "type": "color",
          "id": "item_border_color",
          "label": "Border Color",
          "default": "#eeeeee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Logos",
      "blocks": [{ "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }]
    }
  ]
}
{% endschema %}
