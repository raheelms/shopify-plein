<div class="relative group/country w-full">
  <button
    type="button"
    class="flex items-center justify-between gap-3 w-full px-4 h-12 bg-white border border-gray-100 rounded-xl text-sm font-bold text-gray-900 hover:border-gray-300 hover:shadow-sm transition-all focus:ring-2 focus:ring-gray-900 focus:outline-none"
    aria-expanded="false"
    aria-controls="{{ localPosition }}-country-results"
    aria-describedby="{{ localPosition }}Label"
    onclick="this.nextElementSibling.classList.toggle('hidden')"
  >
    <span class="truncate">
      {{- localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})
    </span>
    {% render 'icon-library', icon: 'arrow-down-s-line', class: 'w-4 h-4 text-gray-400' %}
  </button>
  
  <div 
    id="{{ localPosition }}-country-results" 
    class="absolute bottom-full mb-2 right-0 w-full min-w-[280px] bg-white border border-gray-100 rounded-2xl shadow-2xl overflow-hidden hidden z-[120] backdrop-blur-xl bg-white/95"
  >
    <div class="p-3 border-b border-gray-100 bg-gray-50/50">
      {% if show_country_filter %}
        <div class="relative flex items-center">
          <input
            class="w-full h-10 pl-10 pr-4 bg-white border border-gray-100 rounded-lg text-sm font-medium focus:ring-2 focus:ring-gray-900 focus:outline-none transition-all"
            id="country-filter-input"
            type="search"
            name="country_filter"
            value=""
            placeholder="{{ 'localization.search' | t }}"
            role="combobox"
          >
          <div class="absolute left-3 text-gray-400">
            {% render 'icon-library', icon: 'search-line', class: 'w-4 h-4' %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="max-h-[300px] overflow-y-auto p-2 custom-scrollbar">
      {% if show_popular_countries %}
        <div class="px-3 py-2 text-[10px] font-black text-gray-400 uppercase tracking-widest">
          {{ 'localization.popular_countries_regions' | t }}
        </div>
        <ul role="list" class="space-y-1 mb-4 list-none p-0 m-0">
          {%- for country in popular_countries -%}
            <li>
              <a
                class="flex items-center justify-between p-3 text-sm font-bold rounded-lg transition-all {% if country.iso_code == localization.country.iso_code %}bg-blue-50 text-blue-600{% else %}text-gray-700 hover:bg-gray-50 hover:text-gray-900{% endif %}"
                href="#"
                {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}
                data-value="{{ country.iso_code }}"
              >
                <div class="flex flex-col">
                  <span>{{- country.name }}</span>
                  <span class="text-[10px] font-medium opacity-60">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
                </div>
                {% if country.iso_code == localization.country.iso_code %}
                  {% render 'icon-library', icon: 'check-line', class: 'w-4 h-4' %}
                {% endif %}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {% endif %}

      <div class="px-3 py-2 text-[10px] font-black text-gray-400 uppercase tracking-widest">
        {{ 'localization.all_countries_regions' | t | default: 'All Countries' }}
      </div>
      <ul role="list" class="space-y-1 list-none p-0 m-0">
        {%- for country in localization.available_countries -%}
          <li>
            <a
              class="flex items-center justify-between p-3 text-sm font-bold rounded-lg transition-all {% if country.iso_code == localization.country.iso_code %}bg-blue-50 text-blue-600{% else %}text-gray-700 hover:bg-gray-50 hover:text-gray-900{% endif %}"
              href="#"
              {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}
              data-value="{{ country.iso_code }}"
            >
              <div class="flex flex-col">
                <span>{{- country.name }}</span>
                <span class="text-[10px] font-medium opacity-60">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
              </div>
              {% if country.iso_code == localization.country.iso_code %}
                {% render 'icon-library', icon: 'check-line', class: 'w-4 h-4' %}
              {% endif %}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>
<input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
