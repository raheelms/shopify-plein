{%- style -%}
  .image-grid-section {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  .image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }
  .image-grid__title {
    font-size: {{ section.settings.heading_size }}rem;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 2rem 0;
    text-transform: uppercase;
  }
  .image-grid__item {
    display: block;
    position: relative;
    text-decoration: none;
    transition: transform 0.2s ease;
    border-radius: 8px;
    overflow: hidden;
  }
  .image-grid__item:hover {
    transform: translateY(-2px);
  }
  .image-grid__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .image-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
  }
{%- endstyle -%}

<div class="image-grid-section page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="image-grid__title">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="image-grid">
    {%- for block in section.blocks -%}
      <div class="image-grid__column" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '#' }}" class="image-grid__item">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'image-grid__image', loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg image-grid__image' }}
          {%- endif -%}
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Image Grid (3 Columns)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "unit": "rem",
      "label": "Heading Size",
      "default": 2.2
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Block",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Grid (3 Columns)",
      "blocks": [{ "type": "image_block" }, { "type": "image_block" }, { "type": "image_block" }]
    }
  ]
}
{% endschema %}
