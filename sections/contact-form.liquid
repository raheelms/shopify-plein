<div class="py-12 md:py-24 color-{{ section.settings.color_scheme }} gradient">
  <div class="max-w-[800px] mx-auto px-6">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-gray-900 tracking-tight leading-tight mb-12 text-center">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- liquid
      assign contact_form_class = 'space-y-6'
    -%}

    {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
      {%- if form.posted_successfully? -%}
        <div class="flex items-center gap-4 p-6 rounded-3xl bg-green-50 text-green-700 border border-green-100 mb-8" tabindex="-1" autofocus>
          {% render 'icon-library', icon: 'checkbox-circle-line', class: 'w-6 h-6 shrink-0' %}
          <span class="font-bold">{{ 'templates.contact.form.post_success' | t }}</span>
        </div>
      {%- elsif form.errors -%}
        <div class="p-6 rounded-3xl bg-red-50 text-red-700 border border-red-100 mb-8" role="alert" tabindex="-1" autofocus>
          <div class="flex items-center gap-4 mb-2">
            {% render 'icon-library', icon: 'error-warning-line', class: 'w-6 h-6 shrink-0' %}
            <span class="font-black">{{ 'templates.contact.form.error_heading' | t }}</span>
          </div>
          <ul class="pl-10 list-disc text-sm font-medium" role="list">
            <li>
              <a href="#ContactForm-email" class="hover:underline">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </a>
            </li>
          </ul>
        </div>
      {%- endif -%}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="relative group">
          <input
            class="w-full px-6 py-5 rounded-2xl border-2 border-gray-100 bg-white text-gray-900 font-medium placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 transition-all outline-none"
            autocomplete="name"
            type="text"
            id="ContactForm-name"
            name="contact[{{ 'templates.contact.form.name' | t }}]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            placeholder="{{ 'templates.contact.form.name' | t }}"
          >
        </div>
        <div class="relative group">
          <input
            autocomplete="email"
            type="email"
            id="ContactForm-email"
            class="w-full px-6 py-5 rounded-2xl border-2 border-gray-100 bg-white text-gray-900 font-medium placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 transition-all outline-none {% if form.errors contains 'email' %}border-red-200 bg-red-50{% endif %}"
            name="contact[email]"
            spellcheck="false"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            aria-required="true"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ContactForm-email-error"
            {% endif %}
            placeholder="{{ 'templates.contact.form.email' | t }} *"
          >
          {%- if form.errors contains 'email' -%}
            <small class="absolute -bottom-6 left-0 text-xs font-bold text-red-600" id="ContactForm-email-error">
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        </div>
      </div>

      <div class="relative group">
        <input
          type="tel"
          id="ContactForm-phone"
          class="w-full px-6 py-5 rounded-2xl border-2 border-gray-100 bg-white text-gray-900 font-medium placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 transition-all outline-none"
          autocomplete="tel"
          name="contact[{{ 'templates.contact.form.phone' | t }}]"
          pattern="[0-9\-]*"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          placeholder="{{ 'templates.contact.form.phone' | t }}"
        >
      </div>

      <div class="relative group">
        <textarea
          rows="6"
          id="ContactForm-body"
          class="w-full px-6 py-5 rounded-2xl border-2 border-gray-100 bg-white text-gray-900 font-medium placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 transition-all outline-none resize-none"
          name="contact[{{ 'templates.contact.form.comment' | t }}]"
          placeholder="{{ 'templates.contact.form.comment' | t }}"
        >{{- form.body -}}</textarea>
      </div>

      <div class="pt-4">
        <button type="submit" class="w-full md:w-auto inline-flex items-center justify-center px-12 py-5 rounded-2xl text-lg font-black bg-gray-900 text-white hover:bg-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95">
          {{ 'templates.contact.form.send' | t }}
          {% render 'icon-library', icon: 'send-plane-fill', class: 'ml-3 w-5 h-5' %}
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.contact-form.settings.title.default",
      "label": "t:sections.contact-form.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
