<div 
  id="section-{{ section.id }}" 
  class="relative overflow-hidden"
  style="
    padding-top: {{ section.settings.padding_top_mobile }}px; 
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
    margin-top: {{ section.settings.margin_top_mobile }}px; 
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
    --padding-top-desktop: {{ section.settings.padding_top }}px;
    --padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
    --margin-top-desktop: {{ section.settings.margin_top }}px;
    --margin-bottom-desktop: {{ section.settings.margin_bottom }}px;
  "
>
  <style>
    @media screen and (min-width: 750px) {
      #section-{{ section.id }} {
        padding-top: var(--padding-top-desktop) !important;
        padding-bottom: var(--padding-bottom-desktop) !important;
        margin-top: var(--margin-top-desktop) !important;
        margin-bottom: var(--margin-bottom-desktop) !important;
      }
    }
  </style>

  <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
    {%- if section.settings.heading != blank -%}
      <div 
        class="mb-12 lg:mb-20"
        style="text-align: {{ section.settings.heading_alignment }}; margin-bottom: {{ section.settings.heading_margin_bottom }}px;"
      >
        <h2 
          class="font-black text-gray-900 uppercase tracking-tight leading-tight"
          style="
            font-size: {{ section.settings.heading_size_mobile }}rem;
            font-weight: {{ section.settings.heading_weight }};
            color: {{ section.settings.heading_color }};
            text-transform: {{ section.settings.heading_transform }};
            --font-size-desktop: {{ section.settings.heading_size }}rem;
          "
        >
          <style>
            @media screen and (min-width: 750px) {
              #section-{{ section.id }} h2 {
                font-size: var(--font-size-desktop) !important;
              }
            }
          </style>
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <slider-component class="block relative">
      <div
        class="flex overflow-x-auto pb-8 snap-x snap-mandatory no-scrollbar lg:grid lg:overflow-visible lg:pb-0"
        id="Slider-{{ section.id }}"
        style="
          gap: {{ section.settings.gap_mobile }}px;
          --columns-desktop: {{ section.settings.items_to_show }};
          --gap-desktop: {{ section.settings.gap }}px;
        "
      >
        <style>
          @media screen and (min-width: 750px) {
            #Slider-{{ section.id }} {
              grid-template-columns: repeat(var(--columns-desktop), minmax(0, 1fr));
              gap: var(--gap-desktop) !important;
            }
          }
        </style>
        
        {%- for block in section.blocks -%}
          <div
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="min-w-[70%] sm:min-w-[40%] lg:min-w-0 snap-start group"
            {{ block.shopify_attributes }}
          >
            <a 
              href="{{ block.settings.link | default: '#' }}" 
              class="block relative aspect-square overflow-hidden bg-gray-50 transition-all duration-500 hover:shadow-2xl hover:shadow-gray-200/50"
              style="border-radius: {{ section.settings.image_radius }}px;"
            >
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag: 
                    loading: 'lazy', 
                    class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-110'
                }}
              {%- else -%}
                <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-300 transition-transform duration-700 group-hover:scale-110">
                  {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full fill-current' }}
                </div>
              {%- endif -%}
              
              <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "Featured Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 1.0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "label": "Heading Size (Desktop)",
      "default": 2.0
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 1.0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "label": "Heading Size (Mobile)",
      "default": 1.8
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading Margin Bottom",
      "default": 10
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading Text Style",
      "options": [
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "none", "label": "Normal" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Carousel Control"
    },
    {
      "type": "range",
      "id": "items_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Items to show (Desktop)",
      "default": 6
    },
    {
      "type": "range",
      "id": "items_to_show_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Items to show (Mobile)",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "force_static",
      "label": "Force Static Grid (Disable Carousel)",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap (Mobile)",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 100
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "header",
      "content": "Section Padding & Margin"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
