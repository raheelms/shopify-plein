{%- style -%}
  #section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    #section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .offers-{{ section.id }}__container {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .offers-{{ section.id }}__header {
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    text-align: {{ section.settings.heading_alignment }};
    display: flex;
    justify-content: space-between;
  }

  .offers-{{ section.id }}__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size_mobile }}rem;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    text-transform: {{ section.settings.heading_transform }};
  }

  @media screen and (min-width: 750px) {
    .offers-{{ section.id }}__heading {
      font-size: {{ section.settings.heading_size }}rem;
    }
  }

  .offers-{{ section.id }}__view-all {
    text-decoration: none;
    color: {{ section.settings.link_color }};
    font-size: {{ section.settings.link_size }}rem;
    font-weight: {{ section.settings.link_weight }};
    transition: opacity 0.3s;
  }

  .offers-{{ section.id }}__view-all:hover {
    opacity: 0.8;
  }

  .offers-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.items_per_row_mobile }}, 1fr);
    gap: {{ section.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .offers-{{ section.id }}__grid {
      grid-template-columns: repeat({{ section.settings.items_per_row }}, 1fr);
      gap: {{ section.settings.gap }}px;
    }
  }

  .offer-item-{{ section.id }} {
    position: relative;
    text-decoration: none;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s;
    padding: {{ section.settings.card_padding }}px;
  }

  .offer-item-{{ section.id }}:hover {
    transform: translateY(-5px);
  }

  .offer-item-{{ section.id }}__image-wrapper {
    position: relative;
    padding-bottom: 100%;
    overflow: hidden;
    background: #f5f5f5;
  }

  .offer-item-{{ section.id }}__image-wrapper img {
    position: absolute;
    top: {{ section.settings.image_padding }}px;
    left: {{ section.settings.image_padding }}px;
    width: calc(100% - {{ section.settings.image_padding | times: 2 }}px);
    height: calc(100% - {{ section.settings.image_padding | times: 2 }}px);
    object-fit: contain;
    padding: 8px;
  }

  .offer-item-{{ section.id }}__content {
    padding: 0 1.5rem;
    text-align: {{ section.settings.text_alignment }};
  }

  .offer-item-{{ section.id }}__title {
    margin: 10px 0 0;
    font-size: {{ section.settings.item_title_size }}rem;
    color: {{ section.settings.item_title_color }};
    font-weight: 600;
  }

  .offer-item-{{ section.id }}__badge {
    position: absolute;
    z-index: 1;
    padding: 0.5rem 1rem;
    font-size: {{ section.settings.badge_size }}rem;
    font-weight: {{ section.settings.badge_weight }};
    color: {{ section.settings.badge_text_color }};
    background-color: {{ section.settings.badge_bg_color }};
    border-radius: 4px;
    line-height: 1;

    {% case section.settings.badge_position %}
      {% when 'top-left' %}
        top: 1rem; left: 1rem;
      {% when 'top-right' %}
        top: 1rem; right: 1rem;
      {% when 'bottom-left' %}
        bottom: 1rem; left: 1rem;
      {% when 'bottom-right' %}
        bottom: 1rem; right: 1rem;
    {% endcase %}
  }
  .offers-{{ section.id }}__footer {
    margin-top: 3rem;
    text-align: {{ section.settings.footer_alignment }};
  }

  .offers-{{ section.id }}__footer-text {
    margin: 0;
    font-size: {{ section.settings.footer_text_size }}rem;
    font-weight: {{ section.settings.footer_text_weight }};
    color: {{ section.settings.footer_text_color }};
    line-height: 1.5;
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="offers-{{ section.id }}">
  <div class="offers-{{ section.id }}__container page-width">
    {%- if section.settings.heading != blank or section.settings.view_all_text != blank -%}
      <div class="offers-{{ section.id }}__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="offers-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.view_all_text != blank -%}
          <a href="{{ section.settings.view_all_link | default: '#' }}" class="offers-{{ section.id }}__view-all">
            {{ section.settings.view_all_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="offers-{{ section.id }}__grid">
      {%- for block in section.blocks -%}
        <a
          {{ block.shopify_attributes }}
          href="{{ block.settings.link | default: '#' }}"
          class="offer-item-{{ section.id }}"
        >
          {%- if block.settings.badge_text != blank -%}
            <span class="offer-item-{{ section.id }}__badge">
              {{ block.settings.badge_text }}
            </span>
          {%- endif -%}

          <div class="offer-item-{{ section.id }}__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <h3 class="offer-item-{{ section.id }}__title">
            {{ block.settings.text | default: 'Offer Title' }}
          </h3>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="offers-{{ section.id }}__footer">
        <div class="offers-{{ section.id }}__footer-text">
          {{ section.settings.footer_text }}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

