{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom:
  {{ section.settings.padding_bottom_mobile }}px; margin-top: {{ section.settings.margin_top_mobile }}px; margin-bottom:
  {{ section.settings.margin_bottom_mobile }}px; }

  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top:
  {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; margin-top:
  {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px; } }

  .custom-collection-list__heading { font-size: {{ section.settings.heading_size_mobile }}rem; font-weight:
  {{ section.settings.heading_weight }}; text-transform: {{ section.settings.heading_transform }}; text-align:
  {{ section.settings.heading_alignment }}; margin: 0 0 {{ section.settings.heading_margin_bottom }}px 0; color:
  {{ section.settings.heading_color }}; }

  @media screen and (min-width: 750px) { .custom-collection-list__heading { font-size:
  {{ section.settings.heading_size }}rem; } }

  .custom-collection-list__grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(
  {{- section.settings.columns_mobile -}}
  , 1fr); }

  @media screen and (min-width: 750px) { .custom-collection-list__grid { grid-template-columns: repeat(
  {{- section.settings.columns_desktop -}}
  , 1fr); } }

  .custom-collection-card { display: flex; flex-direction: column; text-decoration: none; color: inherit; transition:
  transform 0.3s ease; padding-top: {{ section.settings.card_padding_top }}px; padding-bottom:
  {{ section.settings.card_padding_bottom }}px; }

  .custom-collection-card:hover { transform: translateY(-5px); }

  .custom-collection-card__image-wrapper { position: relative; width: 100%; aspect-ratio: 1; overflow: hidden;
  border-radius: {{ section.settings.image_border_radius }}px; background: #f5f5f5; margin-bottom:
  {{ section.settings.image_margin_bottom }}px; }

  .custom-collection-card__image { width: 100%; height: 100%; object-fit: contain; padding:
  {{ section.settings.image_padding }}px; transition: transform 0.3s ease; }

  .custom-collection-card:hover .custom-collection-card__image { transform: scale(1.05); }

  .custom-collection-card__title { margin: {{ section.settings.card_margin_top }}px 0 0; font-size:
  {{ section.settings.card_title_size }}rem; font-weight: {{ section.settings.card_title_weight }}; text-align:
  {{ section.settings.card_title_alignment }}; color: {{ section.settings.card_title_color }}; text-transform:
  {{ section.settings.card_title_transform }}; }

  .custom-collection-list__footer { margin-top: 4rem; display: flex; flex-direction: column; align-items:
  {{ section.settings.footer_alignment | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }}; gap: 1.5rem;
  text-align: {{ section.settings.footer_alignment }}; }

  .custom-collection-list__view-all { display: inline-flex; text-decoration: none; padding: 1.2rem 3rem; background-color:
  {{ section.settings.view_all_bg_color }}; color: {{ section.settings.view_all_text_color }}; font-size:
  {{ section.settings.view_all_font_size }}rem; font-weight: {{ section.settings.view_all_font_weight }}; border-radius:
  4px; transition: opacity 0.3s; }

  .custom-collection-list__view-all:hover { opacity: 0.9; }

  .custom-collection-list__footer-text { margin: 0; font-size: {{ section.settings.footer_text_size }}rem; font-weight:
  {{ section.settings.footer_text_weight }}; color: {{ section.settings.footer_text_color }}; line-height: 1.5; }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="custom-collection-list__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="custom-collection-list__grid">
    {%- for collection in section.settings.collection_list -%}
      <a href="{{ collection.url }}" class="custom-collection-card">
        <div class="custom-collection-card__image-wrapper">
          {%- if collection.featured_image != blank -%}
            {{
              collection.featured_image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                class: 'custom-collection-card__image',
                widths: '200, 400, 600',
                alt: collection.title
            }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg custom-collection-card__image' }}
          {%- endif -%}
        </div>
        <h3 class="custom-collection-card__title">{{ collection.title }}</h3>
      </a>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_view_all or section.settings.footer_text != blank -%}
    <div class="custom-collection-list__footer">
      {%- if section.settings.show_view_all and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="custom-collection-list__view-all">
          {{ section.settings.view_all_text | default: 'View All' }}
        </a>
      {%- endif -%}

      {%- if section.settings.footer_text != blank -%}
        <div class="custom-collection-list__footer-text">
          {{ section.settings.footer_text }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Custom Collection List",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 1.0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "label": "Heading Size (Desktop)",
      "default": 2.0
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 1.0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "label": "Heading Size (Mobile)",
      "default": 1.8
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading Margin Bottom",
      "default": 10
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading Text Style",
      "options": [
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "none", "label": "Normal" }
      ],
      "default": "none"
    },
    {
      "type": "collection_list",
