{% comment %}
  Renders a product media gallery. Should be used with 'media-gallery.js'
  Also see 'product-media-modal'

  Accepts:
  - product: {Object} Product liquid object
  - variant_images: {Array} Product images associated with a variant
  - limit: {Number} (optional) When passed, limits the number of media items to render

  Usage:
  {% render 'product-media-gallery' %}
{% endcomment %}

{%- liquid
  assign media_count = product.media.size
  assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
-%}

<media-gallery
  id="MediaGallery-{{ section.id }}"
  role="region"
  class="block relative {% if section.settings.enable_sticky_info %}lg:sticky lg:top-32{% endif %}"
  aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
  data-desktop-layout="{{ section.settings.gallery_layout | default: 'thumbnail' }}"
>
  <div id="GalleryStatus-{{ section.id }}" class="sr-only" role="status"></div>
  
  {%- comment -%} Main Gallery Viewer {%- endcomment -%}
  <slider-component id="GalleryViewer-{{ section.id }}" class="block relative w-full overflow-hidden bg-white border border-gray-200 group/main">
    <a class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 bg-white px-6 py-3 rounded-xl shadow-lg border border-gray-100 font-black text-xs uppercase tracking-widest" href="#ProductInfo-{{ section.id }}">
      {{ 'accessibility.skip_to_product_info' | t }}
    </a>
    
    <ul
      id="Slider-Gallery-{{ section.id }}"
      class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-0 list-none"
      role="list"
    >
      {%- if featured_media != null -%}
        <li
          id="Slide-{{ section.id }}-{{ featured_media.id }}"
          class="flex-shrink-0 w-full snap-center relative"
          data-media-id="{{ section.id }}-{{ featured_media.id }}"
        >
          {%- assign media_position = 1 -%}
          {% render 'product-thumbnail',
            media: featured_media,
            media_count: media_count,
            position: media_position,
            desktop_layout: section.settings.gallery_layout,
            mobile_layout: section.settings.mobile_thumbnails,
            loop: section.settings.enable_video_looping,
            modal_id: section.id,
            xr_button: true,
            media_width: media_width,
            media_fit: section.settings.media_fit,
            constrain_to_viewport: section.settings.constrain_to_viewport,
            lazy_load: false
          %}
        </li>
      {%- endif -%}
      
      {%- for media in product.media -%}
        {%- if media.id == product.selected_or_first_available_variant.featured_media.id -%}{%- continue -%}{%- endif -%}
        {%- if section.settings.hide_variants and variant_images contains media.src -%}{%- continue -%}{%- endif -%}
        
        <li
          id="Slide-{{ section.id }}-{{ media.id }}"
          class="flex-shrink-0 w-full snap-center relative"
          data-media-id="{{ section.id }}-{{ media.id }}"
        >
          {%- liquid
            assign media_position = media_position | default: 0 | plus: 1
            assign lazy_load = true
            if media_position == 1 and featured_media == null
              assign lazy_load = false
            endif
          -%}
          {% render 'product-thumbnail',
            media: media,
            media_count: media_count,
            position: media_position,
            desktop_layout: section.settings.gallery_layout,
            mobile_layout: section.settings.mobile_thumbnails,
            loop: section.settings.enable_video_looping,
            modal_id: section.id,
            xr_button: true,
            media_width: media_width,
            media_fit: section.settings.media_fit,
            constrain_to_viewport: section.settings.constrain_to_viewport,
            lazy_load: lazy_load
          %}
        </li>
      {%- endfor -%}
    </ul>
    
    {%- if media_count > 1 -%}
      <div class="absolute inset-y-0 left-4 flex items-center z-10 transition-opacity">
        <button
          type="button"
          class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[#004c97] border border-[#004c97] shadow-md hover:bg-gray-50 transition-all disabled:opacity-0"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
        >
          {% render 'icon-library', icon: 'arrow-left-s-line', class: 'w-6 h-6' %}
        </button>
      </div>
      
      <div class="absolute inset-y-0 right-4 flex items-center z-10 transition-opacity">
        <button
          type="button"
          class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[#004c97] border border-[#004c97] shadow-md hover:bg-gray-50 transition-all disabled:opacity-0"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
        >
          {% render 'icon-library', icon: 'arrow-right-s-line', class: 'w-6 h-6' %}
        </button>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center bg-gray-900/10 backdrop-blur-md px-4 py-2 rounded-full border border-white/20 shadow-sm md:hidden">
        <span class="slider-counter--current text-[10px] font-black text-gray-900">1</span>
        <span aria-hidden="true" class="mx-2 text-gray-400 font-bold">/</span>
        <span class="slider-counter--total text-[10px] font-black text-gray-400">{{ media_count }}</span>
      </div>
    {%- endif -%}
  </slider-component>

  {%- comment -%} Thumbnails Slider {%- endcomment -%}
  {%- if media_count > 1 and section.settings.gallery_layout contains 'thumbnail' -%}
    <slider-component
      id="GalleryThumbnails-{{ section.id }}"
      class="block mt-8 relative group/thumbs"
    >
      <div class="flex items-center gap-4">
        <button
          type="button"
          class="slider-button w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:border-gray-200 shadow-sm transition-all disabled:opacity-0"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
          data-step="3"
        >
          {% render 'icon-library', icon: 'arrow-left-s-line', class: 'w-6 h-6' %}
        </button>
        
        <ul
          id="Slider-Thumbnails-{{ section.id }}"
          class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-4 list-none py-2"
        >
          {%- if featured_media != null -%}
            <li
              id="Slide-Thumbnails-{{ section.id }}-0"
              class="flex-shrink-0 w-24 aspect-square snap-start"
              data-target="{{ section.id }}-{{ featured_media.id }}"
            >
              <button
                class="w-full h-full relative rounded-md overflow-hidden border-2 border-transparent transition-all hover:border-gray-200 aria-[current=true]:border-[#004c97] aria-[current=true]:shadow-sm bg-gray-50"
                aria-current="true"
                aria-controls="GalleryViewer-{{ section.id }}"
              >
                {{
                  featured_media.preview_image
                  | image_url: width: 416
                  | image_tag:
                    loading: 'lazy',
                    class: 'w-full h-full object-cover select-none',
                    alt: featured_media.alt
                }}
              </button>
            </li>
          {%- endif -%}
          
          {%- for media in product.media -%}
            {%- if media.id == product.selected_or_first_available_variant.featured_media.id -%}{%- continue -%}{%- endif -%}
            <li
              id="Slide-Thumbnails-{{ section.id }}-{{ forloop.index }}"
              class="flex-shrink-0 w-24 aspect-square snap-start"
              data-target="{{ section.id }}-{{ media.id }}"
            >
              <button
                class="w-full h-full relative rounded-md overflow-hidden border-2 border-transparent transition-all hover:border-gray-200 aria-[current=true]:border-[#004c97] aria-[current=true]:shadow-sm bg-gray-50 group"
                aria-controls="GalleryViewer-{{ section.id }}"
                {% if media == product.selected_or_first_available_variant.featured_media or product.selected_or_first_available_variant.featured_media == null and forloop.index == 1 %}aria-current="true"{% endif %}
              >
                {%- if media.media_type == 'model' -%}
                  <span class="absolute top-2 right-2 w-5 h-5 bg-white/90 backdrop-blur-sm rounded-lg flex items-center justify-center shadow-sm z-10 border border-gray-100">
                    {% render 'icon-library', icon: 'box-3-line', class: 'w-3 h-3 text-blue-600' %}
                  </span>
                {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                  <span class="absolute top-2 right-2 w-5 h-5 bg-white/90 backdrop-blur-sm rounded-lg flex items-center justify-center shadow-sm z-10 border border-gray-100">
                    {% render 'icon-library', icon: 'play-fill', class: 'w-3 h-3 text-blue-600' %}
                  </span>
                {%- endif -%}
                
                {{
                  media.preview_image
                  | image_url: width: 416
                  | image_tag:
                    loading: 'lazy',
                    class: 'w-full h-full object-cover select-none transition-transform group-hover:scale-110',
                    alt: media.alt
                }}
              </button>
            </li>
          {%- endfor -%}
        </ul>

        <button
          type="button"
          class="slider-button w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:border-gray-200 shadow-sm transition-all disabled:opacity-0"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
          data-step="3"
        >
          {% render 'icon-library', icon: 'arrow-right-s-line', class: 'w-6 h-6' %}
        </button>
      </div>
    </slider-component>
  {%- endif -%}
</media-gallery>
