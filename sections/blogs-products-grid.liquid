<div class="py-20 lg:py-32 bg-white">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      
      {%- comment -%} Column 1: Blog Posts {%- endcomment -%}
      <div class="space-y-10 lg:space-y-12">
        <div class="flex items-end justify-between border-b border-gray-100 pb-6 lg:pb-8">
          <h2 class="text-2xl lg:text-3xl font-black text-gray-900 uppercase tracking-tight leading-none">
            {{ section.settings.blog_heading }}
          </h2>
          {%- if section.settings.blog != blank -%}
            <a href="{{ blogs[section.settings.blog].url }}" class="text-[10px] font-black text-blue-600 uppercase tracking-[0.2em] hover:text-black transition-colors flex items-center gap-2 mb-1">
              {{ 'sections.featured_blog.view_all' | t }}
              {% render 'icon-library', icon: 'arrow-right-line', class: 'w-3 h-3' %}
            </a>
          {%- endif -%}
        </div>

        <div class="flex flex-col gap-6 lg:gap-8">
          {%- if section.settings.blog != blank -%}
            {%- for article in blogs[section.settings.blog].articles limit: section.settings.blog_posts_to_show -%}
              <a href="{{ article.url }}" class="group flex gap-6 lg:gap-8 p-6 lg:p-8 bg-gray-50/50 border border-gray-100/50 rounded-[2.5rem] transition-all duration-500 hover:shadow-2xl hover:shadow-gray-200/50 hover:bg-white hover:border-blue-100 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-{{ forloop.index | times: 100 }}">
                <div class="shrink-0 w-24 h-24 lg:w-32 lg:h-32 overflow-hidden rounded-[1.5rem] lg:rounded-[2rem] bg-gray-100">
                  {%- if article.image -%}
                    {{ article.image | image_url: width: 400 | image_tag: 
                        loading: 'lazy', 
                        class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-110' 
                    }}
                  {%- else -%}
                    {{ 'blog-apparel-1' | placeholder_svg_tag: 'w-full h-full fill-gray-200 transition-transform duration-700 group-hover:scale-110' }}
                  {%- endif -%}
                </div>
                <div class="flex-1 min-w-0 flex flex-col justify-center py-2">
                  <h3 class="text-sm lg:text-base font-black text-gray-900 uppercase tracking-tight leading-tight group-hover:text-blue-600 transition-colors mb-3 lg:mb-4 line-clamp-2">
                    {{ article.title }}
                  </h3>
                  <p class="text-[11px] lg:text-xs font-medium text-gray-400 uppercase tracking-widest leading-relaxed line-clamp-2">
                    {{ article.excerpt_or_content | strip_html | truncate: 120 }}
                  </p>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..3) -%}
              <div class="group flex gap-6 lg:gap-8 p-6 lg:p-8 bg-gray-50/50 border border-gray-100/50 rounded-[2.5rem]">
                <div class="shrink-0 w-24 h-24 lg:w-32 lg:h-32 overflow-hidden rounded-[1.5rem] lg:rounded-[2rem] bg-gray-100">
                  {{ 'blog-apparel-1' | placeholder_svg_tag: 'w-full h-full fill-gray-200' }}
                </div>
                <div class="flex-1 min-w-0 flex flex-col justify-center py-2">
                  <h3 class="text-sm lg:text-base font-black text-gray-900 uppercase tracking-tight mb-3 lg:mb-4">Blog Post Title</h3>
                  <p class="text-[11px] lg:text-xs font-medium text-gray-400 uppercase tracking-widest leading-relaxed">This is a sample blog post excerpt that will show preview text...</p>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Column 2: Weekly Top Products {%- endcomment -%}
      <div class="space-y-10 lg:space-y-12">
        <div class="flex items-end justify-between border-b border-gray-100 pb-6 lg:pb-8">
          <h2 class="text-2xl lg:text-3xl font-black text-gray-900 uppercase tracking-tight leading-none">
            {{ section.settings.products_heading }}
          </h2>
          {%- if section.settings.collection != blank -%}
            <a href="{{ section.settings.collection.url }}" class="text-[10px] font-black text-blue-600 uppercase tracking-[0.2em] hover:text-black transition-colors flex items-center gap-2 mb-1">
              {{ 'sections.featured_collection.view_all' | t }}
              {% render 'icon-library', icon: 'arrow-right-line', class: 'w-3 h-3' %}
            </a>
          {%- endif -%}
        </div>

        <div class="flex flex-col gap-6 lg:gap-8">
          {%- if section.settings.collection != blank -%}
            {%- for product in section.settings.collection.products limit: 4 -%}
              <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-{{ forloop.index | times: 100 }}">
                {% render 'card-product-weekly', card_product: product %}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="group relative bg-white border border-gray-100 rounded-[2rem] p-5">
                <div class="block mb-4">
                  <h3 class="text-xs font-black text-gray-900 uppercase tracking-[0.1em]">Sample Product Title</h3>
                </div>
                <div class="flex items-center gap-5">
                  <div class="shrink-0 w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center text-gray-200">
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full fill-current' }}
                  </div>
                  <div class="flex-1">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-black text-gray-900 tracking-tighter">12</span>
                      <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest -mt-1">.99</span>
                    </div>
                  </div>
                  <div class="shrink-0">
                    <div class="w-12 h-12 flex items-center justify-center bg-gray-100 text-gray-300 rounded-2xl">
                      {% render 'icon-library', icon: 'shopping-cart-fill', class: 'w-5 h-5' %}
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blogs & Products Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Blog Column"
    },
    {
      "type": "text",
      "id": "blog_heading",
      "label": "Blog Heading",
      "default": "Latest Articles"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "blog_posts_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Blog Posts to Show"
    },
    {
      "type": "header",
      "content": "Products Column"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products Heading",
      "default": "Weekly Top Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Blogs & Products Grid",
      "settings": {
        "blog_heading": "Latest Articles",
        "products_heading": "Weekly Top Products"
      }
    }
  ]
}
{% endschema %}
