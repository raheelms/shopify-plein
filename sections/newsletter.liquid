<div 
  id="Newsletter-{{ section.id }}"
  class="py-12 md:py-24 color-{{ section.settings.color_scheme }} gradient {% if section.settings.full_width == false %}max-w-[1400px] mx-auto px-6 md:px-12 my-12 md:my-24 rounded-3xl{% endif %}"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="max-w-[800px] mx-auto px-6 text-{{ section.settings.alignment }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
        {%- when 'heading' -%}
          <h2
            class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6"
            style="color: {{ block.settings.heading_color }}; font-size: {{ block.settings.heading_font_size }}rem;"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.heading }}
          </h2>
        {%- when 'paragraph' -%}
          <div
            class="text-lg md:text-xl font-medium opacity-80 mb-10 leading-relaxed"
            style="color: {{ block.settings.paragraph_color }}; font-size: {{ block.settings.paragraph_size }}rem;"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </div>
        {%- when 'email_form' -%}
          <div {{ block.shopify_attributes }}>
            {% form 'customer', class: 'max-w-2xl mx-auto' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="relative group">
                <div class="flex flex-col md:flex-row gap-4">
                  <div class="relative flex-grow">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="w-full px-8 py-5 rounded-2xl border-2 border-gray-100 bg-white text-gray-900 font-medium placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 transition-all outline-none shadow-sm group-hover:shadow-md"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="Newsletter-error--{{ section.id }}"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="Newsletter-success--{{ section.id }}"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                  </div>
                  <button
                    type="submit"
                    class="px-10 py-5 rounded-2xl text-lg font-black bg-gray-900 text-white hover:bg-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95 whitespace-nowrap"
                    name="commit"
                    id="Subscribe"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    {{ 'newsletter.button_label' | t }}
                    {% render 'icon-library', icon: 'send-plane-fill', class: 'inline-block ml-2 w-5 h-5' %}
                  </button>
                </div>

                {%- if form.errors -%}
                  <div class="mt-4 flex items-center gap-2 text-sm font-bold text-red-600" id="Newsletter-error--{{ section.id }}">
                    {% render 'icon-library', icon: 'error-warning-line', class: 'w-5 h-5' %}
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </div>
                {%- endif -%}
              </div>

              {%- if form.posted_successfully? -%}
                <div
                  class="mt-8 flex items-center justify-center gap-3 p-6 rounded-3xl bg-green-50 text-green-700 border border-green-100"
                  id="Newsletter-success--{{ section.id }}"
                  tabindex="-1"
                  autofocus
                >
                  {% render 'icon-library', icon: 'checkbox-circle-line', class: 'w-6 h-6' %}
                  <span class="font-bold">{{- 'newsletter.success' | t }}</span>
                </div>
              {%- endif -%}
            {% endform %}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

