{% comment %}
  Variant List Row
{% endcomment %}

{% # theme-check-disable %}
{% assign cart_qty = cart | item_count_for_variant: variant.id %}
{% # theme-check-enable %}

<tr
  class="group transition-all duration-300 hover:bg-white animate-in fade-in slide-in-from-left-2"
  id="Variant-{{ variant.id }}"
  data-variant-id="{{ variant.id }}"
>
  <td class="px-6 py-8">
    <div class="flex items-center gap-6">
      {%- if show_image -%}
        <div class="shrink-0 w-16 h-16 rounded-2xl overflow-hidden border border-gray-100 bg-gray-50 shadow-sm transition-transform duration-500 group-hover:scale-110">
          {% if image %}
            {{
              image
              | image_url: width: 150
              | image_tag:
                loading: 'lazy',
                class: 'w-full h-full object-cover',
                alt: image.alt
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'w-full h-full fill-gray-200' }}
          {% endif %}
        </div>
      {%- endif -%}
      <div class="flex flex-col min-w-0">
        <span class="text-[11px] lg:text-sm font-black text-gray-900 uppercase tracking-tight truncate">{{ item.title | escape }}</span>
        {%- if show_sku and sku != blank -%}
          <span class="text-[9px] font-bold text-gray-400 uppercase tracking-[0.1em] mt-1">{{ sku | escape }}</span>
        {%- endif -%}
        
        <div class="lg:hidden mt-4 space-y-2">
          {%- render 'loading-spinner' -%}
          <div class="text-sm font-black text-blue-600">
            {{ cart | line_items_for: item | sum: 'original_line_price' | money }}
          </div>
        </div>
      </div>
    </div>
  </td>

  <td class="hidden lg:table-cell px-6 py-8">
    {%- liquid
      assign check_against_inventory = true
      if variant.inventory_management != 'shopify' or variant.inventory_policy == 'continue'
        assign check_against_inventory = false
      endif
      if variant.quantity_rule.min > variant.inventory_quantity and check_against_inventory
        assign quantity_rule_soldout = true
      endif

      assign has_qty_rules = false
      if variant.quantity_rule.increment > 1 or variant.quantity_rule.min > 1 or variant.quantity_rule.max != null
        assign has_qty_rules = true
      endif

      assign has_vol_pricing = false
      if variant.quantity_price_breaks.size > 0
        assign has_vol_pricing = true
      endif
    -%}
    
    <quantity-popover class="block">
      <div class="flex items-center gap-4">
        {%- if variant.available == false or quantity_rule_soldout -%}
          <span class="inline-flex items-center px-4 py-2 bg-red-50 text-red-600 text-[9px] font-black uppercase tracking-widest rounded-full border border-red-100">
            {{ 'products.product.sold_out' | t }}
          </span>
        {%- else -%}
          <div class="flex items-center gap-2">
            {% render 'quantity-input', variant: variant, min: 0 %}
            
            {%- if has_qty_rules or has_vol_pricing -%}
              <button
                type="button"
                aria-expanded="false"
                class="w-8 h-8 flex items-center justify-center bg-gray-50 rounded-lg text-gray-400 hover:bg-gray-900 hover:text-white transition-all duration-300"
              >
                {% render 'icon-library', icon: 'information-line', class: 'w-4 h-4' %}
              </button>
              
              <div class="hidden absolute z-50 bg-white p-6 rounded-[2rem] border border-gray-100 shadow-2xl w-64 mt-2 animate-in fade-in slide-in-from-top-2">
                <div class="space-y-4">
                  <p class="text-[10px] font-black text-gray-900 uppercase tracking-widest">
                    {% if has_vol_pricing %}{{ 'products.product.volume_pricing.title' | t }}{% else %}Rules{% endif %}
                  </p>
                  <ul class="space-y-2">
                    {%- if variant.quantity_rule.increment > 1 -%}
                      <li class="text-[9px] font-bold text-gray-400 uppercase tracking-tight">Multiples of {{ variant.quantity_rule.increment }}</li>
                    {%- endif -%}
                    {%- if variant.quantity_rule.min > 1 -%}
                      <li class="text-[9px] font-bold text-gray-400 uppercase tracking-tight">Minimum of {{ variant.quantity_rule.min }}</li>
                    {%- endif -%}
                  </ul>
                  
                  {%- if has_vol_pricing -%}
                    <div class="pt-4 border-t border-gray-50 space-y-2">
                      {%- for price_break in variant.quantity_price_breaks -%}
                        <div class="flex justify-between text-[10px] font-black uppercase">
                          <span class="text-gray-400">{{ price_break.minimum_quantity }}+</span>
                          <span class="text-gray-900">{{ price_break.price | money }}</span>
                        </div>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {% if cart_qty > 0 %}
              <quick-order-list-remove-button data-index="{{ variant.id }}">
                <button
                  class="w-8 h-8 flex items-center justify-center bg-white border border-gray-100 rounded-lg text-gray-300 hover:text-red-500 hover:border-red-100 transition-all duration-300"
                  aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                >
                  {% render 'icon-library', icon: 'close-line', class: 'w-4 h-4' %}
                </button>
              </quick-order-list-remove-button>
            {% endif %}
          </div>
        {%- endif -%}
      </div>
      
      <div class="hidden mt-2 text-[9px] font-black text-red-500 uppercase tracking-tight" id="Quick-order-list-item-error-{{ variant.id }}" role="alert">
        <span class="error-text"></span>
      </div>
    </quantity-popover>
  </td>

  <td class="hidden lg:table-cell px-6 py-8">
    <div class="flex flex-col">
      {%- if item.compare_at_price -%}
        <s class="text-[10px] font-bold text-gray-300 tracking-tight leading-none mb-1">{{ item.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="text-[13px] font-black text-gray-900 tracking-tight">{{ item.price | money }}</span>
      {%- if item.unit_price_measurement -%}
        <div class="text-[9px] font-bold text-gray-400 uppercase mt-1">
          {{ item.unit_price | money }} / {{ item.unit_price_measurement.reference_unit }}
        </div>
      {%- endif -%}
    </div>
  </td>

  <td class="hidden lg:table-cell px-6 py-8 text-right">
    <div class="relative flex items-center justify-end gap-3">
      {%- render 'loading-spinner' -%}
      <span class="text-[15px] font-black text-blue-600 tracking-tight">
        {{ cart | line_items_for: item | sum: 'original_line_price' | money }}
      </span>
    </div>
  </td>
</tr>
