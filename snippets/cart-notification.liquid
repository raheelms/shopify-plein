{% comment %}
  Renders cart notification
  Usage:
  {% render 'cart-notification' %}
{% endcomment %}

<cart-notification class="fixed top-8 right-8 z-[100] pointer-events-none">
  <div 
    id="cart-notification" 
    class="cart-notification focus-inset w-full max-w-md bg-white rounded-[2rem] border border-gray-100 shadow-2xl overflow-hidden pointer-events-auto transition-all duration-500 opacity-0 translate-x-12 [&.is-active]:opacity-100 [&.is-active]:translate-x-0"
    aria-modal="true"
    aria-label="{{ 'general.cart.item_added' | t }}"
    role="dialog"
    tabindex="-1"
  >
    <div class="flex items-center justify-between p-6 bg-gray-50 border-b border-gray-100">
      <h2 class="flex items-center gap-3 text-sm font-black text-gray-900 uppercase tracking-widest">
        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-100 text-green-600">
          {% render 'icon-library', icon: 'check-line', class: 'w-4 h-4' %}
        </span>
        {{ 'general.cart.item_added' | t }}
      </h2>
      <button
        type="button"
        class="w-8 h-8 flex items-center justify-center rounded-xl bg-white border border-gray-100 text-gray-400 hover:text-gray-900 transition-colors"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {% render 'icon-library', icon: 'close-line', class: 'w-4 h-4' %}
      </button>
    </div>

    <div id="cart-notification-product" class="p-6"></div>

    <div class="p-6 bg-gray-50/50 space-y-3">
      <a
        href="{{ routes.cart_url }}"
        id="cart-notification-button"
        class="flex items-center justify-center w-full py-4 px-6 rounded-2xl bg-white border-2 border-gray-900 text-gray-900 font-black hover:bg-gray-50 transition-all active:scale-95"
      >
        {{- 'general.cart.view_empty_cart' | t -}}
      </a>
      <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
        <button class="w-full py-4 px-6 rounded-2xl bg-gray-900 text-white font-black hover:bg-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95" name="checkout">
          {{ 'sections.cart.checkout' | t }}
        </button>
      </form>
      <button type="button" class="w-full text-xs font-black text-gray-400 uppercase tracking-[0.2em] py-2 hover:text-gray-900 transition-colors">
        {{ 'general.continue_shopping' | t }}
      </button>
    </div>
  </div>
</cart-notification>
