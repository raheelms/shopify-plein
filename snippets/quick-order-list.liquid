{% comment %}
  Renders a list of product's variants
{% endcomment %}

{%- assign items_in_cart = cart | line_items_for: product | sum: 'quantity' -%}

<div class="bg-gray-50/50 rounded-[2.5rem] border border-gray-100 overflow-hidden shadow-2xl shadow-gray-200/50">
  <quick-order-list
    class="block"
    id="{{ section.id }}-{{ product.id }}"
    data-section="{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-url="{{ product.url }}"
  >
    <form
      action="{{ routes.cart_update_url }}"
      class="p-4 lg:p-8"
      method="post"
      id="QuickOrderList"
    >
      {% paginate product.variants by section.settings.variants_per_page %}
        <div class="overflow-x-auto rounded-[2rem] bg-white border border-gray-100" id="main-variant-items">
          <table class="w-full text-left border-collapse">
            <caption class="sr-only">
              {{ 'sections.cart.title' | t }}
            </caption>
            <thead>
              <tr class="bg-gray-50/50 border-bottom border-gray-100">
                <th class="px-6 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]" scope="col">
                  {%- if product.has_only_default_variant -%}
                    {{ 'sections.quick_order_list.product' | t }}
                  {%- else -%}
                    {{ 'sections.quick_order_list.variant' | t }}
                  {%- endif -%}
                </th>
                <th class="lg:hidden px-6 py-5 text-right text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]" scope="col">
                  {{ 'sections.quick_order_list.variant_total' | t }}
                </th>
                <th class="hidden lg:table-cell px-6 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]" scope="col">
                  {{ 'products.product.quantity.label' | t }}
                </th>
                <th class="hidden lg:table-cell px-6 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]" scope="col">
                  {{ 'sections.cart.headings.price' | t }}
                </th>
                <th class="hidden lg:table-cell px-6 py-5 text-right text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]" scope="col">
                  {{ 'sections.quick_order_list.variant_total' | t }}
                </th>
              </tr>
            </thead>

            <tbody class="divide-y divide-gray-50">
              {%- if product.has_only_default_variant -%}
                {%- render 'quick-order-list-row',
                  item: product,
                  image: product.featured_media,
                  sku: product.selected_or_first_available_variant.sku,
                  variant: product.selected_or_first_available_variant,
                  show_image: show_image,
                  show_sku: show_sku,
                  is_modal: is_modal
                -%}
              {%- else -%}
                {%- for variant in product.variants -%}
                  {%- render 'quick-order-list-row',
                    item: variant,
                    image: variant.image,
                    sku: variant.sku,
                    variant: variant,
                    show_image: show_image,
                    show_sku: show_sku,
                    is_modal: is_modal
                  -%}
                {%- endfor -%}
              {%- endif -%}
            </tbody>
          </table>
        </div>
        
        {%- if paginate.pages > 1 -%}
          <div class="mt-8 flex justify-center js-paginate">
            {% render 'pagination', paginate: paginate %}
          </div>
        {%- endif -%}
      {%- endpaginate -%}

      <p class="sr-only" id="quick-order-list-live-region-text-{{ product.id }}" aria-live="polite" role="status"></p>
      <p class="sr-only" id="shopping-cart-variant-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{ 'accessibility.loading' | t }}
      </p>
    </form>

    {%- if product.has_only_default_variant == false and product.variants_count > 1 -%}
      <div
        class="bg-gray-50 border-t border-gray-100 p-8 lg:p-12"
        id="quick-order-list-total-{{ product.id }}-{{ section.id }}"
      >
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-12">
          
          <div class="flex flex-col sm:flex-row items-center gap-6">
            <a
              href="{{ routes.cart_url }}"
              class="w-full sm:w-auto px-10 py-5 bg-gray-900 text-white text-[11px] font-black uppercase tracking-widest rounded-2xl hover:bg-blue-600 transition-all duration-300 text-center shadow-xl shadow-gray-200/50"
            >
              {{- 'sections.quick_order_list.view_cart' | t -}}
            </a>
            
            <div class="relative flex items-center gap-4">
              {%- render 'loading-spinner' -%}
              <quick-order-list-remove-all-button
                data-action="confirm"
                class="{% if items_in_cart == 0 %}hidden{% endif %}"
              >
                <button class="flex items-center gap-2 group text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-red-500 transition-colors" type="button">
                  <span class="w-6 h-6 flex items-center justify-center bg-white rounded-lg border border-gray-100 group-hover:border-red-100 shadow-sm transition-all duration-300">
                    {% render 'icon-library', icon: 'close-line', class: 'w-3 h-3' %}
                  </span>
                  <span>{{ 'sections.quick_order_list.remove_all' | t }}</span>
                </button>
              </quick-order-list-remove-all-button>
            </div>
          </div>

          <div class="flex flex-wrap items-center justify-end gap-12 text-right">
            <div class="space-y-1">
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">{{ 'sections.quick_order_list.total_items' | t }}</p>
              <p class="text-2xl font-black text-gray-900">{{ items_in_cart }}</p>
            </div>

            <div class="space-y-1">
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">{{ 'sections.quick_order_list.product_total' | t }}</p>
              <p class="text-2xl font-black text-blue-600">
                {{ cart | line_items_for: product | sum: 'original_line_price' | money }}
              </p>
              {%- if cart.taxes_included -%}
                <p class="text-[9px] font-bold text-gray-300 uppercase tracking-wider">{{ 'sections.cart.taxes_included' | t }}</p>
              {%- endif -%}
            </div>
          </div>

        </div>

        <div class="quick-order-list-total__confirmation hidden mt-8 p-6 bg-red-50 border border-red-100 rounded-3xl flex flex-col sm:flex-row items-center justify-between gap-6">
          <span class="text-[11px] font-bold text-red-900 uppercase tracking-tight text-center sm:text-left">
            {{ 'sections.quick_order_list.remove_all_items_confirmation' | t: quantity: items_in_cart }}
          </span>
          <div class="flex items-center gap-4">
            <quick-order-list-remove-all-button data-action="remove">
              <button class="px-8 py-3 bg-red-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-red-700 transition-colors" type="button">
                {{- 'sections.quick_order_list.remove_all' | t -}}
              </button>
            </quick-order-list-remove-all-button>
            <quick-order-list-remove-all-button data-action="cancel">
              <button class="px-8 py-3 bg-white text-gray-900 text-[10px] font-black uppercase tracking-widest rounded-xl border border-gray-200 hover:border-gray-900 transition-colors" type="button">
                {{- 'sections.quick_order_list.cancel' | t -}}
              </button>
            </quick-order-list-remove-all-button>
          </div>
        </div>

        <script type="application/json" data-cart-contents>
          {{ cart | line_items_for: product | map: "variant_id" | json }}
        </script>
      </div>
    {%- endif -%}
  </quick-order-list>
  
  <template id="QuickOrderListErrorTemplate-{{ product.id }}">
    <div class="flex items-center gap-3 p-4 bg-red-50 text-red-600 rounded-2xl border border-red-100 mt-4">
      {% render 'icon-library', icon: 'error-warning-line', class: 'w-5 h-5 shrink-0' %}
      <span class="quick-order-list-error-message text-[10px] font-black uppercase tracking-tight" role="alert"></span>
    </div>
  </template>
</div>
