<div 
  id="Banner-{{ section.id }}"
  class="relative overflow-hidden bg-gray-100 {% if section.settings.image_height == 'adapt' %}aspect-auto{% elsif section.settings.image_height == 'small' %}min-h-[400px] md:min-h-[500px]{% elsif section.settings.image_height == 'medium' %}min-h-[500px] md:min-h-[700px]{% else %}min-h-[600px] md:min-h-[900px]{% endif %} shadow-2xl rounded-[2.5rem] mx-6 md:mx-12 my-12 md:my-24"
>
  {%- if section.settings.image != blank -%}
    <div class="absolute inset-0 flex {% if section.settings.image_2 != blank %}flex-col md:flex-row{% endif %}">
      <div class="relative flex-grow h-full overflow-hidden">
        {{
          section.settings.image
          | image_url: width: 3840
          | image_tag:
            loading: 'lazy',
            class: 'absolute inset-0 w-full h-full object-cover select-none',
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      </div>
      {%- if section.settings.image_2 != blank -%}
        <div class="relative flex-grow h-full overflow-hidden">
          {{
            section.settings.image_2
            | image_url: width: 3840
            | image_tag:
              loading: 'lazy',
              class: 'absolute inset-0 w-full h-full object-cover select-none',
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          }}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="absolute inset-0 bg-gray-200">
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'w-full h-full object-cover text-gray-400 opacity-50' }}
    </div>
  {%- endif -%}

  {%- comment -%} Mobile-only text below setting is ignored in this refactor to favor a more modern, consistent overlay approach {%- endcomment -%}
  {%- comment -%} Overlay {%- endcomment -%}
  <div class="absolute inset-0 bg-black/{{ section.settings.image_overlay_opacity | times: 10 | divided_by: 100 | at_least: 0 }} pointer-events-none"></div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="relative z-10 w-full h-full flex p-8 md:p-16 lg:p-24 
    {% case section.settings.desktop_content_position %}
      {% when 'top-left' %}items-start justify-start
      {% when 'top-center' %}items-start justify-center
      {% when 'top-right' %}items-start justify-end
      {% when 'middle-left' %}items-center justify-start
      {% when 'middle-center' %}items-center justify-center
      {% when 'middle-right' %}items-center justify-end
      {% when 'bottom-left' %}items-end justify-start
      {% when 'bottom-center' %}items-end justify-center
      {% when 'bottom-right' %}items-end justify-end
    {% endcase %}">
    
    <div class="max-w-2xl w-full text-{{ section.settings.desktop_content_alignment }} 
      {% if section.settings.show_text_box %}bg-white/90 backdrop-blur-xl p-8 md:p-12 rounded-[2rem] shadow-2xl text-gray-900 border border-white/20{% else %}text-white drop-shadow-2xl{% endif %}">
      
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="font-black tracking-tighter leading-none mb-6 
              {% if block.settings.heading_size == 'h2' %}text-3xl md:text-5xl
              {% elsif block.settings.heading_size == 'h1' %}text-4xl md:text-6xl
              {% elsif block.settings.heading_size == 'h0' %}text-5xl md:text-7xl
              {% elsif block.settings.heading_size == 'hxl' %}text-6xl md:text-8xl
              {% else %}text-7xl md:text-9xl
              {% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h2>
          {%- when 'text' -%}
            <div class="mb-10 text-lg md:text-xl font-medium leading-relaxed opacity-90" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div class="flex flex-wrap gap-4 justify-{{ section.settings.desktop_content_alignment | replace: 'left', 'start' | replace: 'right', 'end' }}" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  href="{{ block.settings.button_link_1 | default: '#' }}"
                  class="inline-flex items-center gap-3 px-10 py-5 rounded-2xl text-lg font-black transition-all hover:shadow-xl hover:-translate-y-1 active:scale-95
                  {% if block.settings.button_style_secondary_1 %}bg-white/10 backdrop-blur-md text-white border border-white/20 hover:bg-white hover:text-gray-900{% else %}bg-gray-900 text-white hover:bg-black{% endif %}"
                >
                  {{- block.settings.button_label_1 | escape -}}
                  {% render 'icon-library', icon: 'arrow-right-line', class: 'w-6 h-6' %}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  href="{{ block.settings.button_link_2 | default: '#' }}"
                  class="inline-flex items-center gap-3 px-10 py-5 rounded-2xl text-lg font-black transition-all hover:shadow-xl hover:-translate-y-1 active:scale-95
                  {% if block.settings.button_style_secondary_2 %}bg-white/10 backdrop-blur-md text-white border border-white/20 hover:bg-white hover:text-gray-900{% else %}bg-gray-900 text-white hover:bg-black{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                  {% render 'icon-library', icon: 'arrow-right-line', class: 'w-6 h-6' %}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
