<div class="min-h-[80vh] flex items-center justify-center bg-white py-20 lg:py-32 px-6">
  <div class="w-full max-w-xl">
    <div class="bg-gray-50/50 border border-gray-100/50 rounded-[3rem] p-10 lg:p-16 shadow-2xl shadow-gray-200/20">
      
      <div class="text-center mb-12 space-y-4">
        <h1 class="text-3xl lg:text-4xl font-black text-gray-900 uppercase tracking-tight leading-tight">
          {{ 'customer.reset_password.title' | t }}
        </h1>
        <p class="text-sm font-medium text-gray-400 uppercase tracking-widest leading-relaxed">
          {{ 'customer.reset_password.subtext' | t }}
        </p>
      </div>

      {%- form 'reset_customer_password', class: 'space-y-8' -%}
        {%- if form.errors -%}
          <div class="bg-red-50 border border-red-100 rounded-3xl p-8 mb-8 animate-in fade-in slide-in-from-top-4 duration-500">
            <h2 class="flex items-center gap-3 text-red-600 font-black text-xs uppercase tracking-widest mb-4" tabindex="-1" autofocus>
              {% render 'icon-library', icon: 'error-warning-fill', class: 'w-4 h-4' %}
              {{ 'templates.contact.form.error_heading' | t }}
            </h2>
            <ul class="space-y-2">
              {%- for field in form.errors -%}
                <li class="text-[11px] font-black text-red-500 uppercase tracking-widest pl-7 relative">
                  <span class="absolute left-0 top-1/2 -translate-y-1/2 w-4 h-[2px] bg-red-200"></span>
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    <a href="#{{ field }}" class="hover:text-red-700 transition-colors">
                      {{ form.errors.translated_fields[field] | capitalize }}
                      {{ form.errors.messages[field] }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="space-y-2">
          <label for="password" class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">
            {{ 'customer.reset_password.password' | t }}
          </label>
          <div class="relative group">
            <input
                type="password"
                name="customer[password]"
                id="password"
                autocomplete="new-password"
                {% if form.errors contains 'password' %}
                aria-invalid="true"
                aria-describedby="password-error"
                {% endif %}
                class="w-full px-8 py-5 bg-white border border-gray-100 rounded-2xl text-sm font-medium focus:ring-4 focus:ring-blue-50 focus:border-blue-200 outline-none transition-all group-hover:border-gray-200"
                placeholder="{{ 'customer.reset_password.password' | t }}"
            >
            <div class="absolute right-6 top-1/2 -translate-y-1/2 text-gray-300 group-hover:text-gray-400 transition-colors">
                {% render 'icon-library', icon: 'lock-password-line', class: 'w-5 h-5' %}
            </div>
          </div>
          {%- if form.errors contains 'password' -%}
            <p id="password-error" class="flex items-center gap-2 text-[10px] font-black text-red-500 uppercase tracking-widest mt-2 ml-1">
              {% render 'icon-library', icon: 'error-warning-fill', class: 'w-3 h-3' %}
              {{ form.errors.translated_fields.password | capitalize }}
              {{ form.errors.messages.password }}
            </p>
          {%- endif -%}
        </div>

        <div class="space-y-2">
          <label for="password_confirmation" class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">
            {{ 'customer.reset_password.password_confirm' | t }}
          </label>
          <div class="relative group">
            <input
                type="password"
                name="customer[password_confirmation]"
                id="password_confirmation"
                autocomplete="new-password"
                {% if form.errors contains 'password_confirmation' %}
                aria-invalid="true"
                aria-describedby="password_confirmation-error"
                {% endif %}
                class="w-full px-8 py-5 bg-white border border-gray-100 rounded-2xl text-sm font-medium focus:ring-4 focus:ring-blue-50 focus:border-blue-200 outline-none transition-all group-hover:border-gray-200"
                placeholder="{{ 'customer.reset_password.password_confirm' | t }}"
            >
            <div class="absolute right-6 top-1/2 -translate-y-1/2 text-gray-300 group-hover:text-gray-400 transition-colors">
                {% render 'icon-library', icon: 'lock-password-line', class: 'w-5 h-5' %}
            </div>
          </div>
          {%- if form.errors contains 'password_confirmation' -%}
            <p id="password_confirmation-error" class="flex items-center gap-2 text-[10px] font-black text-red-500 uppercase tracking-widest mt-2 ml-1">
              {% render 'icon-library', icon: 'error-warning-fill', class: 'w-3 h-3' %}
              {{ form.errors.translated_fields.password_confirmation | capitalize }}
              {{ form.errors.messages.password_confirmation }}
            </p>
          {%- endif -%}
        </div>

        <button class="w-full py-6 bg-gray-900 text-white rounded-2xl font-black text-xs uppercase tracking-[0.25em] hover:bg-black hover:shadow-2xl hover:shadow-gray-900/10 transition-all active:scale-[0.98] mt-4">
          {{ 'customer.reset_password.submit' | t }}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-reset-password.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
