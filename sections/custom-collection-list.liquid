      "min": 1,
      "max": 8,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on Mobile",
      "default": 2
    },
    {
      "type": "header",
      "content": "Collection Card Settings"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "unit": "rem",
      "label": "Card Title Size",
      "default": 1.6
    },
    {
      "type": "select",
      "id": "card_title_weight",
