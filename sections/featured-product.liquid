{% comment %}
  Refactored Featured Product - Tailwind CSS Only
  Premium SaaS Aesthetic
{% endcomment %}

{%- liquid
  assign product = section.settings.product
  if product == null
    assign placeholder = true
  endif
-%}

<product-info
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="false"
  data-url="{{ product.url }}"
  class="block bg-white overflow-hidden"
>
  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12 py-16 lg:py-24">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="text-3xl lg:text-4xl font-black text-gray-900 tracking-tight leading-tight mb-12 lg:mb-16">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
      
      {%- comment -%} [[ MEDIA COLUMN ]] {%- endcomment -%}
      <div class="lg:col-span-7">
        <div class="relative bg-gray-50 rounded-[2.5rem] overflow-hidden border border-gray-100 shadow-sm p-8 lg:p-12">
          {%- unless placeholder -%}
            {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
            {% render 'product-media-gallery', product: product, variant_images: variant_images, limit: 1 %}
          {%- else -%}
            <div class="aspect-square flex items-center justify-center">
              {{ 'product-apparel-1' | placeholder_svg_tag: 'w-2/3 h-2/3 text-gray-200' }}
            </div>
          {%- endunless -%}
        </div>
      </div>

      {%- comment -%} [[ INFO COLUMN ]] {%- endcomment -%}
      <div class="lg:col-span-5 space-y-10">
        <div id="ProductInfo-{{ section.id }}" class="space-y-8">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                <p class="text-[11px] font-black text-gray-400 uppercase tracking-widest leading-none mb-2" {{ block.shopify_attributes }}>
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <h2 class="text-4xl lg:text-5xl font-black text-gray-900 leading-[1.1] tracking-tight" {{ block.shopify_attributes }}>
                  {%- unless placeholder -%}
                    {{ product.title | escape }}
                  {%- else -%}
                    {{ 'onboarding.product_title' | t }}
                  {%- endunless -%}
                </h2>
              {%- when 'price' -%}
                <div id="price-{{ section.id }}" class="pb-8 border-b border-gray-100" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    placeholder: placeholder,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'text-3xl lg:text-4xl'
                  -%}
                </div>
              {%- when 'quantity_selector' -%}
                <div class="space-y-4" {{ block.shopify_attributes }}>
                   <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest">Quantity</label>
                   {% render 'quantity-selector', product: product, product_form_id: product_form_id %}
                </div>
              {%- when 'variant_picker' -%}
                <div class="space-y-6" {{ block.shopify_attributes }}>
                   {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
                </div>
              {%- when 'buy_buttons' -%}
                <div {{ block.shopify_attributes }}>
                  {%- render 'buy-buttons',
                    block: block,
                    product: product,
                    product_form_id: product_form_id,
                    section_id: section.id
                  -%}
                </div>
              {%- when 'rating' -%}
                 {%- if product.metafields.reviews.rating.value != blank -%}
                    <div class="flex items-center gap-2">
                       <div class="flex text-yellow-400">
                          {% render 'icon-library', icon: 'star-fill', class: 'w-4 h-4' %}
                       </div>
                       <span class="text-sm font-bold text-gray-900">{{ product.metafields.reviews.rating.value }}</span>
                       <span class="text-xs text-gray-400">({{ product.metafields.reviews.rating_count }})</span>
                    </div>
                 {%- endif -%}
              {%- when 'icon-with-text' -%}
                {% render 'icon-with-text', block: block %}
            {%- endcase -%}
          {%- endfor -%}
        </div>

        <div class="pt-8 border-t border-gray-100">
          <a
            {% if product == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ product.url }}"
            {% endif %}
            class="group inline-flex items-center gap-2 text-sm font-black text-gray-900 uppercase tracking-widest"
          >
            <span>{{ 'products.product.view_full_details' | t }}</span>
            <div class="w-8 h-8 rounded-full border border-gray-100 flex items-center justify-center transition-all group-hover:bg-gray-900 group-hover:text-white">
               {% render 'icon-library', icon: 'arrow-right-line', class: 'w-4 h-4' %}
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>

  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
</product-info>


