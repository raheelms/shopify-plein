{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      <li>
        {%- if link.links != blank -%}
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item flex items-center gap-1 px-4 py-3 text-[15px] font-semibold text-gray-800 hover:text-[#004c97] cursor-pointer transition-colors list-none {% if link.child_active %}text-[#004c97]{% endif %}"
              >
                <span>{{- link.title | escape -}}</span>
                {% render 'icon-library', icon: 'arrow-down-s-line', class: 'w-3.5 h-3.5 opacity-40' %}
              </summary>
              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                tabindex="-1"
              >
                <ul
                  class="max-w-[1440px] mx-auto px-12 py-10 grid grid-cols-4 lg:grid-cols-5 gap-12"
                  role="list"
                >
                  {%- for childlink in link.links -%}
                    <li class="space-y-6">
                      <a
                        id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                        href="{{ childlink.url }}"
                        class="block text-xs font-black text-[#004c97] uppercase tracking-widest border-b border-blue-50 pb-4 transition-all hover:pl-2"
                        {% if childlink.current %}
                          aria-current="page"
                        {% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>
                      {%- if childlink.links != blank -%}
                        <ul class="list-none p-0 m-0 space-y-4" role="list">
                          {%- for grandchildlink in childlink.links -%}
                            <li>
                              <a
                                id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                href="{{ grandchildlink.url }}"
                                class="text-xs font-bold text-gray-500 hover:text-[#004c97] transition-colors {% if grandchildlink.current %}text-[#004c97]{% endif %}"
                                {% if grandchildlink.current %}
                                  aria-current="page"
                                {% endif %}
                              >
                                {{ grandchildlink.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}

                  {%- comment -%} Promo Block {%- endcomment -%}
                  {%- assign promo_block = null -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'mega_menu_promo' and block.settings.menu_handle == link.handle -%}
                      {%- assign promo_block = block -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- if promo_block != null -%}
                    <li class="col-span-1 lg:col-span-2">
                      <a href="{{ promo_block.settings.link }}" class="block group/promo relative overflow-hidden rounded-3xl shadow-2xl transition-transform hover:scale-[1.02] active:scale-95 duration-500">
                        <div class="aspect-video bg-gray-50">
                          {%- if promo_block.settings.image -%}
                            {{ promo_block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover transition-transform duration-700 group-hover/promo:scale-110' }}
                          {%- else -%}
                            {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-gray-100 placeholder-svg transition-transform duration-700 group-hover/promo:scale-110' }}
                          {%- endif -%}
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover/promo:opacity-100 transition-opacity"></div>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
            </details>
          </header-menu>
        {%- else -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item flex items-center px-5 py-3 text-[15px] font-black text-gray-900 uppercase tracking-widest hover:bg-blue-50 hover:text-[#004c97] rounded-2xl transition-all duration-300 {% if link.current %}bg-blue-50 text-[#004c97]{% endif %}"
            {% if link.current %}
              aria-current="page"
            {% endif %}
          >
            <span>{{- link.title | escape -}}</span>
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
