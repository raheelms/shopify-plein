<div class="group/card-collection relative flex flex-col h-full bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:-translate-y-2">
  <div class="relative w-full aspect-[4/5] overflow-hidden">
    {%- if card_collection.featured_image -%}
      {{
        card_collection.featured_image
        | image_url: width: 1500
        | image_tag:
          loading: 'lazy',
          class: 'w-full h-full object-cover transition-transform duration-700 group-hover/card-collection:scale-110',
          sizes: "(min-width: 1200px) 450px, (min-width: 750px) calc((100vw - 10rem) / 2), calc(100vw - 3rem)",
          widths: '165, 330, 535, 750, 1000, 1500'
      }}
    {%- else -%}
      {{ placeholder_image | default: 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-50 text-gray-200 transition-transform duration-700 group-hover/card-collection:scale-110' }}
    {%- endif -%}

    {%- comment -%} Overlay Gradient {%- endcomment -%}
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/60 to-transparent pointer-events-none opacity-0 group-hover/card-collection:opacity-100 transition-opacity duration-500"></div>
  </div>

  <div class="p-8 flex flex-col flex-grow">
    <h3 class="text-2xl font-black text-gray-900 tracking-tight leading-tight mb-2 group-hover/card-collection:text-blue-600 transition-colors">
      <a href="{{ card_collection.url | default: '#' }}" class="after:absolute after:inset-0 after:z-10">
        {%- if card_collection.title != blank -%}
          {{- card_collection.title | escape -}}
        {%- else -%}
          {{ 'onboarding.collection_title' | t }}
        {%- endif -%}
      </a>
    </h3>

    {%- if card_collection.description != blank -%}
      <div class="text-gray-500 text-sm font-medium line-clamp-2 mb-6">
        {{- card_collection.description | strip_html -}}
      </div>
    {%- endif -%}

    <div class="mt-auto flex items-center gap-2 text-gray-900 font-black text-sm uppercase tracking-widest group-hover/card-collection:gap-4 transition-all">
      <span>{{ 'sections.collection_list.view_collection' | t | default: 'View Collection' }}</span>
      {% render 'icon-library', icon: 'arrow-right-line', class: 'w-5 h-5 text-blue-600' %}
    </div>
  </div>
</div>
