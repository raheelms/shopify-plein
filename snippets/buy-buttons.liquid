<div {{ block.shopify_attributes }} class="space-y-6">
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif
    -%}

    <product-form
      class="block"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
    >
      {%- comment -%} Error Message {%- endcomment -%}
      <div class="hidden items-center gap-4 p-5 mb-8 bg-red-50 border border-red-100 rounded-2xl text-red-600 text-sm font-bold shadow-sm" role="alert">
        {% render 'icon-library', icon: 'error-warning-line', class: 'w-6 h-6 shrink-0' %}
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'block',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          disabled
          class="product-variant-id"
        >

        <div class="space-y-8">
          {%- comment -%} [[ BUY ROW ]] {%- endcomment -%}
          <div class="flex flex-col sm:flex-row items-stretch gap-4">
            {%- comment -%} Quantity Selector {%- endcomment -%}
            <div class="w-full sm:w-32 shrink-0">
               {%- render 'quantity-selector', product: product, product_form_id: product_form_id -%}
            </div>

            {%- comment -%} Add to Cart Button {%- endcomment -%}
            <button
              id="ProductSubmitButton-{{ section_id }}"
              type="submit"
              name="add"
              class="flex-1 h-12 bg-[#115e59] text-white rounded-lg font-bold text-base transition-colors hover:bg-[#0f766e] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 group/btn"
              {% if product.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >
              {%- if product.selected_or_first_available_variant.available == false -%}
                <span>{{ 'products.product.sold_out' | t }}</span>
              {%- else -%}
                {% render 'icon-library', icon: 'shopping-cart-line', class: 'w-5 h-5' %}
                <span>Voeg toe</span>
              {%- endif -%}
            </button>
          </div>
          
          {%- comment -%} Dynamic Checkout {%- endcomment -%}
          {%- if block.settings.show_dynamic_checkout -%}
            <div class="pt-4 animate-in fade-in slide-in-from-bottom-2 duration-500">
                {{ form | payment_button }}
            </div>
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>
  {%- else -%}
    <div class="p-8 bg-gray-50 rounded-2xl border border-gray-100 flex items-center justify-center shadow-inner">
        <button
          type="button"
          class="w-full h-16 bg-gray-200 text-gray-500 font-black rounded-2xl cursor-not-allowed opacity-50 uppercase tracking-widest text-sm"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="block mt-12 p-8 bg-blue-50/30 border border-blue-100 rounded-3xl shadow-sm overflow-hidden relative"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
    >
      <template>
        <pickup-availability-preview class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-2xl bg-white shadow-md flex items-center justify-center shrink-0 border border-blue-100">
             {% render 'icon-library', icon: 'map-pin-2-fill', class: 'text-blue-600 w-6 h-6' %}
          </div>
          <div class="space-y-2">
            <p class="text-sm font-bold text-gray-800 leading-tight">Checking availability for pickup...</p>
            <button class="text-blue-600 text-[10px] font-black underline decoration-blue-200 underline-offset-4 hover:decoration-blue-600 uppercase tracking-widest transition-all">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>
    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>
