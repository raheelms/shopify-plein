{% comment %}
  Refactored Kruidvat Product Card - Tailwind CSS Only
  Premium SaaS Aesthetic
{% endcomment %}

{%- if card_product and card_product != empty -%}
  <div class="group relative bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500 overflow-hidden flex flex-col h-full">
    
    {%- comment -%} [[ BADGE ]] {%- endcomment -%}
    {%- if card_product.compare_at_price > card_product.price or card_product.tags contains 'offer' -%}
      <div class="absolute top-4 left-4 z-10">
        <span class="bg-blue-600 text-white text-[10px] font-black px-3 py-1.5 rounded-xl uppercase tracking-widest shadow-lg">
          {{ 'products.product.on_sale' | t | default: 'Offer' }}
        </span>
      </div>
    {%- endif -%}

    {%- comment -%} [[ IMAGE SECTION ]] {%- endcomment -%}
    <div class="relative aspect-square overflow-hidden bg-gray-50 p-6">
      <a href="{{ card_product.url }}" class="block w-full h-full">
        {%- if card_product.featured_media -%}
          <img
            src="{{ card_product.featured_media | image_url: width: 533 }}"
            alt="{{ card_product.featured_media.alt | escape }}"
            loading="lazy"
            class="w-full h-full object-contain mix-blend-multiply transition-transform duration-700 group-hover:scale-110"
            width="{{ card_product.featured_media.width }}"
            height="{{ card_product.featured_media.height }}"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full text-gray-200' }}
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} [[ CONTENT SECTION ]] {%- endcomment -%}
    <div class="p-6 flex flex-col flex-1 gap-4">
      
      <div class="space-y-2">
        {%- comment -%} Brand/Category (Optional but common in SaaS) {%- endcomment -%}
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none">
          {{ card_product.vendor | default: 'Premium Quality' }}
        </p>
        
        <h3 class="text-base font-bold text-gray-900 leading-tight group-hover:text-blue-600 transition-colors">
          <a href="{{ card_product.url }}">
            {{ card_product.title | escape }}
          </a>
        </h3>
      </div>

      {%- comment -%} Variant Info {%- endcomment -%}
      {%- liquid
        assign current_variant = card_product.selected_or_first_available_variant
        assign variant_title = current_variant.title
        if variant_title == 'Default Title'
          assign variant_title = ''
        endif
        assign variant_weight = current_variant.weight | weight_with_unit
        if current_variant.weight == 0
          assign variant_weight = ''
        endif
      -%}
      
      <div class="flex items-center gap-3 text-[11px] font-medium text-gray-500">
        {%- if variant_title != blank or variant_weight != blank -%}
          <span>{{ variant_title }}{% if variant_title != blank and variant_weight != blank %} • {% endif %}{{ variant_weight }}</span>
        {%- endif -%}
        
        {%- if current_variant.unit_price_measurement -%}
          <span class="text-gray-300">|</span>
          <span>{{ current_variant.unit_price | money }} / {{ current_variant.unit_price_measurement.reference_unit }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Rating {%- endcomment -%}
      <div class="flex items-center gap-1.5">
        <div class="flex items-center text-yellow-400">
          {% render 'icon-library', icon: 'star-fill', class: 'w-3 h-3' %}
        </div>
        <span class="text-xs font-bold text-gray-900">
          {{- card_product.metafields.reviews.rating.value | default: '4.8' -}}
        </span>
        <span class="text-[10px] font-medium text-gray-400">
          ({{ card_product.metafields.reviews.rating_count | default: '12' }})
        </span>
      </div>

      {%- comment -%} Bottom Row: Price & Buy {%- endcomment -%}
      <div class="mt-auto pt-4 flex items-center justify-between border-t border-gray-50">
        <div class="flex flex-col">
          <span class="text-lg font-black text-gray-900">{{ card_product.price | money }}</span>
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="text-xs text-gray-400 line-through decoration-gray-300">{{ card_product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        {%- form 'product', card_product -%}
          <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            name="add"
            class="flex items-center justify-center w-10 h-10 bg-gray-900 text-white rounded-xl hover:bg-blue-600 transition-colors shadow-sm active:scale-95 disabled:bg-gray-200 disabled:cursor-not-allowed"
            {% unless card_product.available %}
              disabled
            {% endunless %}
          >
            {%- if card_product.available -%}
              {% render 'icon-library', icon: 'shopping-cart-line', class: 'w-5 h-5' %}
              <span class="sr-only">Add to cart</span>
            {%- else -%}
              <span class="text-[8px] font-black uppercase tracking-tighter">Out</span>
            {%- endif -%}
          </button>
        {%- endform -%}
      </div>

    </div>
  </div>
{%- else -%}
  {%- comment -%} [[ PLACEHOLDER ]] {%- endcomment -%}
  <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 space-y-4">
    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center">
      {{ 'product-1' | placeholder_svg_tag: 'w-24 h-24 text-gray-200' }}
    </div>
    <div class="space-y-2">
      <div class="h-2 w-12 bg-gray-100 rounded"></div>
      <div class="h-4 w-3/4 bg-gray-100 rounded"></div>
    </div>
    <div class="flex justify-between items-center pt-4">
      <div class="h-6 w-16 bg-gray-100 rounded"></div>
      <div class="h-10 w-10 bg-gray-100 rounded-xl"></div>
    </div>
  </div>
{%- endif -%}

