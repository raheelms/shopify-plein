<div class="py-12 md:py-24 color-{{ section.settings.section_color_scheme }} gradient">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="flex flex-col {% if section.settings.layout == 'text_first' %}md:flex-row-reverse{% else %}md:flex-row{% endif %} items-center gap-12 md:gap-24">
      
      {%- comment -%} Media Column {%- endcomment -%}
      <div class="w-full {% if section.settings.desktop_image_width == 'small' %}md:w-1/3{% elsif section.settings.desktop_image_width == 'medium' %}md:w-1/2{% else %}md:w-3/5{% endif %}">
        <div class="relative overflow-hidden rounded-3xl shadow-2xl shadow-gray-200/50 group">
          <div class="{% if section.settings.image != blank %}aspect-square md:aspect-auto{% else %}aspect-video bg-gray-50 flex items-center justify-center{% endif %}">
            {%- if section.settings.image != blank -%}
              {%- liquid
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                assign fetch_priority = 'auto'
                if section.index == 1
                  assign fetch_priority = 'high'
                endif
              -%}
              {{
                section.settings.image
                | image_url: width: 1500
                | image_tag: 
                  widths: widths,
                  fetchpriority: fetch_priority,
                  class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105'
              }}
            {%- else -%}
              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'w-full h-full text-gray-200' }}
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} Content Column {%- endcomment -%}
      <div class="w-full {% if section.settings.desktop_image_width == 'small' %}md:w-2/3{% elsif section.settings.desktop_image_width == 'medium' %}md:w-1/2{% else %}md:w-2/5{% endif %}">
        <div class="flex flex-col {% if section.settings.desktop_content_alignment == 'center' %}items-center text-center{% elsif section.settings.desktop_content_alignment == 'right' %}items-end text-right{% else %}items-start text-left{% endif %} space-y-8">
          {%- for block in section.blocks -%}
            {% case block.type %}
              {%- when 'caption' -%}
                <span class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-blue-600 text-xs font-black uppercase tracking-widest" {{ block.shopify_attributes }}>
                  {{ block.settings.caption | escape }}
                </span>
              {%- when 'heading' -%}
                <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 leading-[1.1] tracking-tight" {{ block.shopify_attributes }}>
                  {{ block.settings.heading }}
                </h2>
              {%- when 'text' -%}
                <div class="text-lg md:text-xl text-gray-500 font-medium leading-relaxed max-w-2xl" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link | default: '#' }}"
                    class="inline-flex items-center justify-center px-10 py-5 rounded-2xl text-lg font-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95 {% if block.settings.button_style_secondary %}bg-white text-gray-900 border-2 border-gray-100 hover:border-gray-900{% else %}bg-gray-900 text-white hover:bg-black{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.button_label | escape }}
                    {% render 'icon-library', icon: 'arrow-right-line', class: 'ml-3 w-5 h-5' %}
                  </a>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</div>

