<div class="flex justify-center pt-12 lg:pt-16 pb-12">
  <nav class="flex items-center gap-2" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
    <ul class="flex items-center gap-2 list-none p-0 m-0" role="list">
      
      {%- if paginate.previous -%}
        <li>
          <a
            href="{{ paginate.previous.url }}{{ anchor }}"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-[#004c97] hover:border-[#004c97] transition-all group"
            aria-label="{{ 'general.pagination.previous' | t }}"
          >
            {% render 'icon-library', icon: 'arrow-left-s-line', class: 'w-5 h-5 group-hover:-translate-x-0.5 transition-transform' %}
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        <li>
          {%- if part.is_link -%}
            <a
              href="{{ part.url }}{{ anchor }}"
              class="flex items-center justify-center min-w-[2.5rem] h-10 rounded-lg bg-white border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-[#004c97] hover:border-[#004c97] transition-all"
              aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
            >
              {{- part.title -}}
            </a>
          {%- else -%}
            {%- if part.title == paginate.current_page -%}
              <span
                class="flex items-center justify-center min-w-[2.5rem] h-10 rounded-lg bg-[#004c97] border border-[#004c97] text-sm font-bold text-white"
                aria-current="page"
                aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
              >
                {{- part.title -}}
              </span>
            {%- else -%}
              <span class="flex items-center justify-center min-w-[2.5rem] h-10 text-sm font-medium text-gray-400">
                {{ part.title }}
              </span>
            {%- endif -%}
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- if paginate.next -%}
        <li>
          <a
            href="{{ paginate.next.url }}{{ anchor }}"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-[#004c97] hover:border-[#004c97] transition-all group"
            aria-label="{{ 'general.pagination.next' | t }}"
          >
            {% render 'icon-library', icon: 'arrow-right-s-line', class: 'w-5 h-5 group-hover:translate-x-0.5 transition-transform' %}
          </a>
        </li>
      {%- endif -%}

    </ul>
  </nav>
</div>
