<div class="py-20 lg:py-32 bg-white overflow-hidden">
  <div class="mx-auto px-6 lg:px-12 {% if section.settings.layout == 'section' %}max-w-[1400px]{% elsif section.settings.layout == 'none' %}max-w-full{% endif %}">
    
    <div class="{% if section.settings.image == blank %}max-w-3xl mx-auto{% else %}w-full{% endif %}">
      
      <div 
        class="mb-16 lg:mb-24 animate-in fade-in slide-in-from-top-4 duration-700"
        style="text-align: {{ section.settings.heading_alignment }};"
      >
        {%- if section.settings.caption != blank -%}
          <p class="text-[10px] font-black text-blue-600 uppercase tracking-[0.3em] mb-4">
            {{ section.settings.caption | escape }}
          </p>
        {% endif %}
        {%- if section.settings.heading != blank -%}
          <h2 class="text-3xl lg:text-5xl font-black text-gray-900 uppercase tracking-tight leading-tight">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
      </div>

      <div class="grid grid-cols-1 {% if section.settings.image != blank %}lg:grid-cols-2 lg:items-center gap-16 lg:gap-24{% endif %} {% if section.settings.desktop_layout == 'image_second' %}lg:flex-row-reverse{% endif %}">
        
        {%- if section.settings.image != blank -%}
          <div class="{% if section.settings.desktop_layout == 'image_second' %}lg:order-2{% endif %} animate-in fade-in slide-in-from-left-4 duration-1000">
            <div class="relative aspect-square overflow-hidden rounded-[3rem] shadow-2xl shadow-gray-200/50">
              {{
                section.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  class: 'w-full h-full object-cover transition-transform duration-1000 hover:scale-110'
              }}
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
            </div>
          </div>
        {% endif %}

        <div class="space-y-4 lg:space-y-6 animate-in fade-in slide-in-from-right-4 duration-1000">
          {%- for block in section.blocks -%}
            <details
              id="Details-{{ block.id }}-{{ section.id }}"
              class="group bg-gray-50/50 border border-gray-100/50 rounded-[2rem] overflow-hidden transition-all duration-500 hover:bg-white hover:border-blue-100 hover:shadow-2xl hover:shadow-gray-200/50"
              {% if section.settings.open_first_collapsible_row and forloop.first %}
                open
              {% endif %}
              {{ block.shopify_attributes }}
            >
              <summary class="list-none flex items-center justify-between p-8 lg:p-10 cursor-pointer select-none">
                <div class="flex items-center gap-6">
                  <div class="shrink-0 w-10 h-10 flex items-center justify-center bg-white rounded-xl shadow-sm text-gray-900 group-open:bg-gray-900 group-open:text-white transition-all duration-300">
                    {% render 'icon-accordion', icon: block.settings.icon %}
                  </div>
                  <h3 class="text-sm lg:text-base font-black text-gray-900 uppercase tracking-tight group-open:text-blue-600 transition-colors">
                    {{ block.settings.heading | default: block.settings.page.title | escape }}
                  </h3>
                </div>
                <div class="shrink-0 transition-transform duration-500 group-open:rotate-180">
                  {% render 'icon-library', icon: 'arrow-down-s-line', class: 'w-6 h-6 text-gray-300 group-hover:text-gray-900' %}
                </div>
              </summary>
              <div class="px-8 lg:px-10 pb-10 lg:pb-12 animate-in fade-in slide-in-from-top-2 duration-500">
                <div class="prose prose-sm prose-gray max-w-none text-[11px] lg:text-xs font-medium text-gray-400 uppercase tracking-widest leading-relaxed">
                  {{ block.settings.row_content }}
                  {{ block.settings.page.content }}
                </div>
              </div>
            </details>
          {%- endfor -%}
        </div>

      </div>
    </div>
  </div>
</div>

