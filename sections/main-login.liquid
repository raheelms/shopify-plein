<div class="bg-white py-20 lg:py-32">
  <div class="max-w-[1440px] mx-auto px-8 lg:px-12">
    <div class="max-w-md mx-auto">
      
      {%- comment -%} [[ RECOVER PASSWORD FORM ]] {%- endcomment -%}
      <div id="recover" class="scroll-mt-32 hidden target:block animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="text-center space-y-4 mb-12">
          <h1 class="text-4xl lg:text-5xl font-black text-gray-900 tracking-tight uppercase">{{ 'customer.recover_password.title' | t }}</h1>
          <p class="text-gray-500 font-medium">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>

        {%- form 'recover_customer_password', class: 'space-y-6' -%}
          {% assign recover_success = form.posted_successfully? %}
          <div class="space-y-4">
            <div class="relative group">
              <input
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                class="w-full px-6 py-5 bg-gray-50 border border-gray-100 rounded-2xl text-sm text-gray-900 focus:ring-4 focus:ring-blue-50 focus:border-blue-200 focus:bg-white outline-none transition-all font-medium placeholder:text-gray-300 {% if form.errors %} border-red-200 bg-red-50/30 {% endif %}"
                placeholder="{{ 'customer.login_page.email' | t }}"
                {% if form.errors %}autofocus aria-invalid="true" aria-describedby="RecoverEmail-email-error"{% endif %}
              >
              <label for="RecoverEmail" class="sr-only">{{ 'customer.login_page.email' | t }}</label>
            </div>
            
            {%- if form.errors -%}
              <p id="RecoverEmail-email-error" class="flex items-center gap-2 text-red-500 text-xs font-bold leading-relaxed px-2">
                {% render 'icon-library', icon: 'error-warning-line', class: 'w-4 h-4' %}
                {{ form.errors.messages.form }}
              </p>
            {%- endif -%}
          </div>

          <div class="space-y-4 pt-2">
            <button class="w-full flex items-center justify-center py-5 bg-gray-900 text-white rounded-2xl font-black text-xs uppercase tracking-[0.25em] hover:bg-black transition-all shadow-xl hover:shadow-gray-200 active:scale-[0.98]">
              {{ 'customer.login_page.submit' | t }}
            </button>
            <a href="#login" class="block text-center text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-gray-900 transition-colors">
              {{ 'customer.login_page.cancel' | t }}
            </a>
          </div>
        {%- endform -%}
      </div>

      {%- comment -%} [[ LOGIN FORM ]] {%- endcomment -%}
      <div id="login" class="scroll-mt-32 target:animate-in target:fade-in target:slide-in-from-bottom-4 duration-700 [:not(:target)_&]:block [:target_&]:hidden">
        <div class="text-center space-y-4 mb-12">
          <h1 class="text-4xl lg:text-5xl font-black text-gray-900 tracking-tight uppercase leading-tight">{{ 'customer.login_page.title' | t }}</h1>
          <p class="text-gray-400 font-black text-[10px] uppercase tracking-[0.3em]">Access Your Command Center</p>
        </div>

        {%- if recover_success == true -%}
          <div class="mb-8 p-4 bg-green-50 border border-green-100 rounded-2xl flex items-center gap-4 text-green-700 text-xs font-bold animate-in fade-in zoom-in-95" tabindex="-1" autofocus>
            {% render 'icon-library', icon: 'checkbox-circle-line', class: 'w-5 h-5 text-green-500' %}
            {{ 'customer.recover_password.success' | t }}
          </div>
        {%- endif -%}

        {%- form 'customer_login', novalidate: 'novalidate', class: 'space-y-6' -%}
          {%- if form.errors -%}
            <div class="p-6 bg-red-50 border border-red-100 rounded-2xl space-y-3" tabindex="-1" autofocus>
                <h2 class="flex items-center gap-3 text-red-700 text-sm font-black uppercase tracking-tight">
                    {% render 'icon-library', icon: 'error-warning-line', class: 'w-5 h-5 text-red-500' %}
                    {{ 'templates.contact.form.error_heading' | t }}
                </h2>
                <div class="text-red-500 text-xs font-medium pl-8">
                    {{ form.errors | default_errors }}
                </div>
            </div>
          {%- endif -%}

          {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
            <section name="sign-in-with-shop-provider" class="pb-4">
              {{ shop | login_button: hide_button: hide_shop_login_button }}
              {%- unless hide_shop_login_button -%}
                <p class="text-center text-[10px] font-black text-gray-300 uppercase tracking-widest mt-6 mb-2 relative">
                    <span class="bg-white px-4 relative z-10">{{ 'customer.login_page.alternate_provider_separator' | t }}</span>
                    <span class="absolute top-1/2 left-0 w-full h-px bg-gray-100 -z-0"></span>
                </p>
              {%- endunless -%}
            </section>
          {%- endif -%}

          <div class="space-y-4">
            <div class="group">
              <input
                type="email"
                name="customer[email]"
                id="CustomerEmail"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                class="w-full px-6 py-5 bg-gray-50 border border-gray-100 rounded-2xl text-sm text-gray-900 focus:ring-4 focus:ring-blue-50 focus:border-blue-200 focus:bg-white outline-none transition-all font-medium placeholder:text-gray-300 {% if form.errors contains 'form' %} border-red-200 bg-red-50/30 {% endif %}"
                placeholder="{{ 'customer.login_page.email' | t }}"
              >
              <label for="CustomerEmail" class="sr-only">{{ 'customer.login_page.email' | t }}</label>
            </div>

            {%- if form.password_needed -%}
              <div class="space-y-2">
                <div class="group">
                  <input
                    type="password"
                    name="customer[password]"
                    id="CustomerPassword"
                    autocomplete="current-password"
                    class="w-full px-6 py-5 bg-gray-50 border border-gray-100 rounded-2xl text-sm text-gray-900 focus:ring-4 focus:ring-blue-50 focus:border-blue-200 focus:bg-white outline-none transition-all font-medium placeholder:text-gray-300 {% if form.errors contains 'form' %} border-red-200 bg-red-50/30 {% endif %}"
                    placeholder="{{ 'customer.login_page.password' | t }}"
                  >
                  <label for="CustomerPassword" class="sr-only">{{ 'customer.login_page.password' | t }}</label>
                </div>
                <div class="text-right">
                    <a href="#recover" class="text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-blue-600 transition-colors">
                    {{ 'customer.login_page.forgot_password' | t }}
                    </a>
                </div>
              </div>
            {%- endif -%}
          </div>

          <div class="space-y-6 pt-2">
            <button class="w-full flex items-center justify-center py-5 bg-gray-900 text-white rounded-2xl font-black text-xs uppercase tracking-[0.25em] hover:bg-black transition-all shadow-xl hover:shadow-gray-200 active:scale-[0.98]">
              {{ 'customer.login_page.sign_in' | t }}
            </button>
            <div class="text-center space-y-4">
                <p class="text-[10px] font-black text-gray-300 uppercase tracking-widest">New to the community?</p>
                <a href="{{ routes.account_register_url }}" class="inline-flex items-center gap-2 px-8 py-3 bg-white border border-gray-100 text-gray-900 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-gray-50 transition-all shadow-sm">
                  {{ 'customer.login_page.create_account' | t }}
                  {% render 'icon-library', icon: 'user-add-line', class: 'w-3.5 h-3.5 text-gray-400' %}
                </a>
            </div>
          </div>
        {%- endform -%}
      </div>

      {%- if shop.checkout.guest_login -%}
        <div class="mt-20 pt-12 border-t border-gray-100 text-center space-y-8">
          <h2 class="text-xl font-black text-gray-900 uppercase tracking-tight">{{ 'customer.login_page.guest_title' | t }}</h2>
          {%- form 'guest_login' -%}
            <button class="inline-flex items-center justify-center px-10 py-4 bg-gray-100 text-gray-900 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-gray-200 transition-all active:scale-95">
              {{ 'customer.login_page.guest_continue' | t }}
            </button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
