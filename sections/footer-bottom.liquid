{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .footer-bottom__container {
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.alignment }};
    text-align: {{ section.settings.alignment }};
    gap: 2rem;
    color: {{ section.settings.text_color }};
  }

  @media screen and (min-width: 750px) {
    .footer-bottom__container {
      flex-direction: row;
      justify-content: {% if section.settings.alignment == 'center' %}center{% elsif section.settings.alignment == 'flex-end' %}flex-end{% else %}space-between{% endif %};
      align-items: center;
    }
  }

  .footer-bottom__copyright {
    font-size: {{ section.settings.copyright_size }}rem;
    font-weight: {{ section.settings.copyright_weight }};
    line-height: 1.5;
  }

  .footer-bottom__social {
    display: flex;
    align-items: center;
    gap: {{ section.settings.social_gap }}px;
  }

  .footer-bottom__social .list-social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    gap: {{ section.settings.social_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-bottom__social .list-social__link {
    color: {{ section.settings.social_icon_color }} !important;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .footer-bottom__social .list-social__link:hover {
    color: {{ section.settings.social_icon_hover_color }} !important;
    transform: scale(1.1);
  }

  .footer-bottom__social .list-social__link .svg-wrapper,
  .footer-bottom__social .list-social__link svg {
    width: {{ section.settings.social_icon_size }}px !important;
    height: {{ section.settings.social_icon_size }}px !important;
  }
{%- endstyle -%}

<div class="footer-bottom section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="footer-bottom__container">
      <div class="footer-bottom__copyright">
        {%- assign copyright_year = 'now' | date: '%Y' -%}
        {%- assign copyright_text = section.settings.copyright_text
          | replace: '[year]', copyright_year
          | replace: '[shop_name]', shop.name
        -%}
        {{ copyright_text }}
      </div>

      {%- if section.settings.show_social -%}
        <div class="footer-bottom__social">
          {%- render 'social-icons' -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer Bottom",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Overall Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#888888"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Copyright Settings"
    },
    {
      "type": "inline_richtext",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "&copy; [year] [shop_name]. Alle rechten voorbehouden.",
      "info": "Use [year] for the current year and [shop_name] for your store name."
    },
    {
      "type": "range",
      "id": "copyright_size",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "unit": "rem",
      "label": "Font Size",
      "default": 1.2
    },
    {
      "type": "select",
      "id": "copyright_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Social Media Settings"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Media Icons",
      "default": true
    },
    {
      "type": "range",
      "id": "social_icon_size",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Icon Size",
      "default": 20
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Icon Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "social_icon_hover_color",
      "label": "Icon Hover Color",
      "default": "#0057ae"
    },
    {
      "type": "range",
      "id": "social_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between icons",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Footer Bottom"
    }
  ]
}
{% endschema %}
